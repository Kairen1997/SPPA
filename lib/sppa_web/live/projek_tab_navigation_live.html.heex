<Layouts.app flash={@flash} current_scope={@current_scope} full_width={true}>
  <div class="fixed inset-0 flex h-screen bg-gradient-to-br from-gray-50 to-gray-100 z-50">
    <%!-- Overlay --%>
    <div
      class={[
        "fixed inset-0 bg-blue-900/60 z-40 transition-opacity duration-300",
        if(@sidebar_open, do: "opacity-100", else: "opacity-0 pointer-events-none")
      ]}
      phx-click="close_sidebar"
    >
    </div>
    <%!-- Sidebar --%>
    <.dashboard_sidebar
      sidebar_open={@sidebar_open}
      dashboard_path={~p"/dashboard"}
      logo_src={~p"/images/logojpkn.png"}
      current_scope={@current_scope}
    /> <%!-- Main Content --%>
    <div class="flex-1 flex flex-col overflow-hidden">
      <%!-- Header --%>
      <header class="bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-700 px-3 sm:px-6 py-3 sm:py-4 flex items-center shadow-md relative gap-2 sm:gap-4">
        <div
          class="flex items-center gap-2 sm:gap-4 flex-shrink-0"
          style="max-width: min(30%, 200px);"
        >
          <button
            phx-click="toggle_sidebar"
            class="text-white hover:text-blue-100 hover:bg-blue-500/40 p-1.5 sm:p-2 rounded-lg transition-all duration-200 flex-shrink-0"
          >
            <.icon name="hero-bars-3" class="w-5 h-5 sm:w-6 sm:h-6" />
          </button>
          <.header_logos />
        </div>

        <div class="flex-1 flex justify-center min-w-0"><.system_title /></div>

        <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
          <.header_actions
            notifications_open={@notifications_open}
            notifications_count={@notifications_count}
            activities={@activities}
            profile_menu_open={@profile_menu_open}
            current_scope={@current_scope}
          />
        </div>
      </header>
      <%!-- Content --%>
      <main class="flex-1 overflow-y-auto bg-gradient-to-br from-gray-50 to-white p-6 md:p-8">
        <div class="max-w-7xl mx-auto">
          <%!-- Back Button (without project title above tabs) --%>
          <div class="mb-6">
            <div class="flex items-center gap-4">
              <.link
                navigate={~p"/projek"}
                class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm transition-all duration-200 hover:border-gray-300 hover:bg-gray-50 hover:text-gray-900 hover:shadow"
              >
                <span>Kembali ke Senarai Sistem</span>
              </.link>
            </div>
          </div>
          <%!-- Navigation Tabs --%>
          <div
            id="project-tabs-navigation"
            class="bg-white rounded-xl shadow-sm border border-gray-200 mb-6 overflow-hidden"
          >
            <div class="bg-gray-50 border-b border-gray-200">
              <nav
                class="flex flex-wrap gap-0.5 px-4 pt-2 pb-0"
                aria-label="Tab navigasi projek"
              >
                <.link
                  patch={~p"/projek/#{@project.id}?tab=soal-selidik"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "Soal Selidik",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  Soal Selidik
                </.link>
                <.link
                  patch={~p"/projek/#{@project.id}?tab=analisis-dan-rekabentuk"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "Analisis dan Rekabentuk",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  Analisis dan Rekabentuk
                </.link>
                <.link
                  patch={~p"/projek/#{@project.id}?tab=jadual-projek"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "Jadual Projek",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  Jadual Projek
                </.link>
                <.link
                  patch={~p"/projek/#{@project.id}?tab=pengaturcaraan"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "Pengaturcaraan",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  Pengaturcaraan
                </.link>
                <.link
                  patch={~p"/projek/#{@project.id}?tab=pengurus-perubahan"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "Pengurusan Perubahan",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  Pengurusan Perubahan
                </.link>
                <.link
                  patch={~p"/projek/#{@project.id}?tab=uat"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "UAT",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  UAT
                </.link>
                <.link
                  patch={~p"/projek/#{@project.id}?tab=ujian-keselamatan"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "Ujian Keselamatan",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  Ujian Keselamatan
                </.link>
                <.link
                  patch={~p"/projek/#{@project.id}?tab=penempatan"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "Penempatan",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  Penempatan
                </.link>
                <.link
                  patch={~p"/projek/#{@project.id}?tab=penyerahan"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "Penyerahan",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  Penyerahan
                </.link>
                <.link
                  patch={~p"/projek/#{@project.id}?tab=maklumbalas-pelanggan"}
                  class={[
                    "px-4 py-3 text-sm font-semibold rounded-t-lg transition-all duration-200 whitespace-nowrap -mb-px",
                    if(@current_tab == "Maklumbalas Pelanggan",
                      do: "bg-white text-blue-600 border border-b-0 border-gray-200 shadow-sm",
                      else:
                        "text-gray-600 hover:text-gray-900 hover:bg-gray-100/80 border border-transparent"
                    )
                  ]}
                >
                  Maklumbalas Pelanggan
                </.link>
              </nav>
            </div>
          </div>
          <%!-- Tab Content --%>
          <%= cond do %>
            <% @current_tab == "Soal Selidik" -> %>
              <div class="space-y-6">
                <div class="flex flex-wrap items-center justify-end gap-3 mb-4 print:hidden">
                  <div class="flex gap-3">
                    <.link
                      id="edit-soal-selidik-form"
                      navigate={~p"/soal-selidik?project_id=#{@project.id}"}
                      class="inline-flex items-center gap-2 px-4 py-2 bg-white hover:bg-gray-50 text-gray-900 font-medium rounded-lg border border-gray-200 transition-colors duration-200 shadow-sm hover:shadow"
                    >
                      <.icon name="hero-pencil-square" class="w-5 h-5 text-gray-700" />
                      <span>Edit Borang</span>
                    </.link>
                    <button
                      id="print-soal-selidik-btn"
                      phx-hook="PrintDocument"
                      data-target="soal-selidik-document"
                      type="button"
                      title="Cetak borang"
                      class="inline-flex items-center justify-center p-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors duration-200 shadow-md hover:shadow-lg"
                    >
                      <.icon name="hero-printer" class="w-5 h-5" />
                    </button>
                  </div>
                </div>

                <div
                  id="soal-selidik-document"
                  class="bg-white rounded-xl shadow-lg border border-gray-200 p-8 print:shadow-none print:border-0"
                >
                  <%= if @soal_selidik_pdf_data do %>
                    <%!-- Document Header --%>
                    <div class="mb-6 text-center">
                      <div class="flex justify-end mb-3">
                        <span class="text-xs text-gray-600 font-bold">
                          {@soal_selidik_pdf_data.document_id}
                        </span>
                      </div>

                      <div class="flex justify-center mb-4">
                        <img
                          src={~p"/images/logojpkn.png"}
                          alt="Logo JPKN"
                          class="h-16 w-auto object-contain"
                        />
                      </div>

                      <h2 class="text-xl font-bold text-gray-900 mb-3 uppercase tracking-wide leading-tight">
                        Soal Selidik Kajian Keperluan Pembangunan Aplikasi
                      </h2>

                      <div class="text-sm text-gray-700 font-medium text-left mb-4 flex items-center gap-2">
                        <span>Nama Sistem :</span>
                        <span class="font-semibold text-gray-900">
                          {@soal_selidik_pdf_data.nama_sistem}
                        </span>
                      </div>
                    </div>
                    <%!-- Functional Requirements Section --%>
                    <div class="mb-6">
                      <h3 class="text-lg font-bold text-blue-700 mb-4 uppercase border-b-2 border-blue-500 pb-2">
                        FUNCTIONAL REQUIREMENT
                      </h3>

                      <div class="space-y-4">
                        <%= for category <- @soal_selidik_pdf_data.fr_categories do %>
                          <div class="border border-gray-300 rounded-lg overflow-hidden mb-4">
                            <div class="bg-blue-100 px-4 py-2 border-b border-gray-400">
                              <h4 class="font-semibold text-gray-900 uppercase tracking-wide text-sm">
                                {category.title}
                              </h4>
                            </div>

                            <div class="p-2 overflow-x-auto">
                              <table class="w-full border-collapse text-xs">
                                <thead>
                                  <tr class="bg-gray-100 border border-gray-400">
                                    <th
                                      class="px-3 py-2 text-left font-semibold text-gray-700 border-r border-gray-400"
                                      style="width: 6%;"
                                    >
                                      No
                                    </th>

                                    <th
                                      class="px-3 py-2 text-left font-semibold text-gray-700 border-r border-gray-400"
                                      style="width: 40%;"
                                    >
                                      Soalan
                                    </th>

                                    <th
                                      class="px-3 py-2 text-left font-semibold text-gray-700 border-r border-gray-400"
                                      style="width: 27%;"
                                    >
                                      Maklumbalas
                                    </th>

                                    <th
                                      class="px-3 py-2 text-left font-semibold text-gray-700"
                                      style="width: 27%;"
                                    >
                                      Catatan
                                    </th>
                                  </tr>
                                </thead>

                                <tbody class="divide-y divide-gray-300">
                                  <%= for question <- category.questions do %>
                                    <tr>
                                      <td class="px-3 py-2 border-r border-gray-400 align-top">
                                        <div class="px-2 py-1 text-sm font-medium text-gray-900">
                                          {question.no}
                                        </div>
                                      </td>

                                      <td class="px-3 py-2 border-r border-gray-400 align-top">
                                        <div class="px-2 py-1 text-sm text-gray-800">
                                          {question_data =
                                            Map.get(
                                              @soal_selidik_pdf_data.fr_data,
                                              category.key,
                                              %{}
                                            )
                                            |> Map.get("#{question.no}", %{})

                                          soalan =
                                            if is_map(question_data) do
                                              Map.get(question_data, "soalan") ||
                                                Map.get(question_data, :soalan) ||
                                                ""
                                            else
                                              ""
                                            end

                                          if soalan != "" do
                                            soalan
                                          else
                                            question.soalan || ""
                                          end}
                                        </div>
                                      </td>

                                      <td class="px-3 py-2 border-r border-gray-400 align-top">
                                        <div class="px-2 py-1 text-sm text-gray-700">
                                          {question_data =
                                            Map.get(
                                              @soal_selidik_pdf_data.fr_data,
                                              category.key,
                                              %{}
                                            )
                                            |> Map.get("#{question.no}", %{})

                                          cond do
                                            is_map(question_data) ->
                                              maklumbalas =
                                                Map.get(question_data, "maklumbalas") ||
                                                  Map.get(question_data, :maklumbalas) ||
                                                  Map.get(question_data, "_unused_maklumbalas") ||
                                                  Map.get(question_data, :_unused_maklumbalas)

                                              cond do
                                                is_list(maklumbalas) ->
                                                  Enum.join(maklumbalas, ", ")

                                                is_binary(maklumbalas) and maklumbalas != "" ->
                                                  maklumbalas

                                                true ->
                                                  ""
                                              end

                                            true ->
                                              ""
                                          end}
                                        </div>
                                      </td>

                                      <td class="px-3 py-2 align-top">
                                        <div class="px-2 py-1 text-sm text-gray-700">
                                          {question_data =
                                            Map.get(
                                              @soal_selidik_pdf_data.fr_data,
                                              category.key,
                                              %{}
                                            )
                                            |> Map.get("#{question.no}", %{})

                                          if is_map(question_data) do
                                            catatan =
                                              Map.get(question_data, "catatan") ||
                                                Map.get(question_data, :catatan) ||
                                                Map.get(question_data, "_unused_catatan") ||
                                                Map.get(question_data, :_unused_catatan)

                                            catatan || ""
                                          else
                                            ""
                                          end}
                                        </div>
                                      </td>
                                    </tr>
                                  <% end %>
                                </tbody>
                              </table>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                    <%!-- Non-Functional Requirements Section --%>
                    <div class="mb-6">
                      <h3 class="text-lg font-bold text-blue-700 mb-4 uppercase border-b-2 border-blue-500 pb-2">
                        NON-FUNCTIONAL REQUIREMENT
                      </h3>

                      <div class="space-y-4">
                        <%= for category <- @soal_selidik_pdf_data.nfr_categories do %>
                          <div class="border border-gray-300 rounded-lg overflow-hidden mb-4">
                            <div class="bg-blue-100 px-4 py-2 border-b border-gray-400">
                              <h4 class="font-semibold text-gray-900 uppercase tracking-wide text-sm">
                                {category.title}
                              </h4>
                            </div>

                            <div class="p-2 overflow-x-auto">
                              <table class="w-full border-collapse text-xs">
                                <thead>
                                  <tr class="bg-gray-100 border border-gray-400">
                                    <th
                                      class="px-3 py-2 text-left font-semibold text-gray-700 border-r border-gray-400"
                                      style="width: 6%;"
                                    >
                                      No
                                    </th>

                                    <th
                                      class="px-3 py-2 text-left font-semibold text-gray-700 border-r border-gray-400"
                                      style="width: 40%;"
                                    >
                                      Soalan
                                    </th>

                                    <th
                                      class="px-3 py-2 text-left font-semibold text-gray-700 border-r border-gray-400"
                                      style="width: 27%;"
                                    >
                                      Maklumbalas
                                    </th>

                                    <th
                                      class="px-3 py-2 text-left font-semibold text-gray-700"
                                      style="width: 27%;"
                                    >
                                      Catatan
                                    </th>
                                  </tr>
                                </thead>

                                <tbody class="divide-y divide-gray-300">
                                  <%= for question <- category.questions do %>
                                    <tr>
                                      <td class="px-3 py-2 border-r border-gray-400 align-top">
                                        <div class="px-2 py-1 text-sm font-medium text-gray-900">
                                          {question.no}
                                        </div>
                                      </td>

                                      <td class="px-3 py-2 border-r border-gray-400 align-top">
                                        <div class="px-2 py-1 text-sm text-gray-800">
                                          {question_data =
                                            Map.get(
                                              @soal_selidik_pdf_data.nfr_data,
                                              category.key,
                                              %{}
                                            )
                                            |> Map.get("#{question.no}", %{})

                                          soalan =
                                            if is_map(question_data) do
                                              Map.get(question_data, "soalan") ||
                                                Map.get(question_data, :soalan) ||
                                                ""
                                            else
                                              ""
                                            end

                                          if soalan != "" do
                                            soalan
                                          else
                                            question.soalan || ""
                                          end}
                                        </div>
                                      </td>

                                      <td class="px-3 py-2 border-r border-gray-400 align-top">
                                        <div class="px-2 py-1 text-sm text-gray-700">
                                          {question_data =
                                            Map.get(
                                              @soal_selidik_pdf_data.nfr_data,
                                              category.key,
                                              %{}
                                            )
                                            |> Map.get("#{question.no}", %{})

                                          cond do
                                            is_map(question_data) ->
                                              maklumbalas =
                                                Map.get(question_data, "maklumbalas") ||
                                                  Map.get(question_data, :maklumbalas) ||
                                                  Map.get(question_data, "_unused_maklumbalas") ||
                                                  Map.get(question_data, :_unused_maklumbalas)

                                              cond do
                                                is_list(maklumbalas) ->
                                                  Enum.join(maklumbalas, ", ")

                                                is_binary(maklumbalas) and maklumbalas != "" ->
                                                  maklumbalas

                                                true ->
                                                  ""
                                              end

                                            true ->
                                              ""
                                          end}
                                        </div>
                                      </td>

                                      <td class="px-3 py-2 align-top">
                                        <div class="px-2 py-1 text-sm text-gray-700">
                                          {question_data =
                                            Map.get(
                                              @soal_selidik_pdf_data.nfr_data,
                                              category.key,
                                              %{}
                                            )
                                            |> Map.get("#{question.no}", %{})

                                          if is_map(question_data) do
                                            catatan =
                                              Map.get(question_data, "catatan") ||
                                                Map.get(question_data, :catatan) ||
                                                Map.get(question_data, "_unused_catatan") ||
                                                Map.get(question_data, :_unused_catatan)

                                            catatan || ""
                                          else
                                            ""
                                          end}
                                        </div>
                                      </td>
                                    </tr>
                                  <% end %>
                                </tbody>
                              </table>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                    <%!-- Disediakan Oleh Section --%>
                    <div class="mb-2">
                      <h3 class="text-lg font-bold text-gray-900 mb-4">Disediakan Oleh :</h3>

                      <p class="text-sm text-gray-600 mb-6 italic">
                        (Diisi oleh Pengurus Projek/Pembangun Sistem)
                      </p>

                      <div class="space-y-4">
                        <div>
                          <label class="block text-sm font-medium text-gray-700 mb-1">
                            Nama:
                          </label>
                          <div class="px-3 py-2 border border-gray-400 rounded bg-gray-50 text-sm text-gray-900 min-h-[40px]">
                            {Map.get(@soal_selidik_pdf_data.disediakan_oleh, :nama) ||
                              Map.get(@soal_selidik_pdf_data.disediakan_oleh, "nama") || ""}
                          </div>
                        </div>

                        <div>
                          <label class="block text-sm font-medium text-gray-700 mb-1">
                            Jawatan:
                          </label>
                          <div class="px-3 py-2 border border-gray-400 rounded bg-gray-50 text-sm text-gray-900 min-h-[40px]">
                            {Map.get(@soal_selidik_pdf_data.disediakan_oleh, :jawatan) ||
                              Map.get(@soal_selidik_pdf_data.disediakan_oleh, "jawatan") || ""}
                          </div>
                        </div>

                        <div>
                          <label class="block text-sm font-medium text-gray-700 mb-1">
                            Tarikh:
                          </label>
                          <div class="px-3 py-2 border border-gray-400 rounded bg-gray-50 text-sm text-gray-900 min-h-[40px]">
                            {Map.get(@soal_selidik_pdf_data.disediakan_oleh, :tarikh) ||
                              Map.get(@soal_selidik_pdf_data.disediakan_oleh, "tarikh") || ""}
                          </div>
                        </div>
                      </div>
                    </div>
                  <% else %>
                    <div class="text-center py-12">
                      <div class="flex flex-col items-center justify-center text-gray-400">
                        <.icon name="hero-document-text" class="w-16 h-16 mb-4" />
                        <p class="text-sm font-medium text-gray-600 mb-2">
                          Tiada data Soal Selidik untuk dipaparkan.
                        </p>

                        <p class="text-xs text-gray-500">
                          Sila klik butang "Edit Borang" di atas untuk menambah atau mengisi soal selidik untuk projek ini.
                        </p>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% @current_tab == "Analisis dan Rekabentuk" -> %>
              <div class="space-y-6">
                <div class="flex justify-end gap-3 mb-4 print:hidden">
                  <.link
                    id="edit-analisis-form"
                    navigate={~p"/analisis-dan-rekabentuk?project_id=#{@project.id}"}
                    class="inline-flex items-center gap-2 px-4 py-2 bg-white hover:bg-gray-50 text-gray-900 font-medium rounded-lg border border-gray-200 transition-colors duration-200 shadow-sm hover:shadow"
                  >
                    <.icon name="hero-pencil-square" class="w-5 h-5 text-gray-700" />
                    <span>Edit Borang</span>
                  </.link>
                  <button
                    id="print-analisis-btn"
                    phx-hook="PrintDocument"
                    data-target="analisis-document"
                    type="button"
                    title="Cetak borang"
                    class="inline-flex items-center justify-center p-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors duration-200 shadow-md hover:shadow-lg"
                  >
                    <.icon name="hero-printer" class="w-5 h-5" />
                  </button>
                </div>

                <div
                  id="analisis-document"
                  class="bg-white rounded-xl shadow-lg border border-gray-200 p-8 print:shadow-none print:border-0"
                  style="font-family: Arial, sans-serif; font-size: 11pt;"
                >
                  <%= if assigns[:analisis_pdf_data] do %>
                    <div class="mb-6">
                      <div class="flex justify-between items-start mb-3">
                        <div class="flex-1"></div>

                        <div class="flex-1 flex justify-center">
                          <img
                            src={~p"/images/logojpkn.png"}
                            alt="Logo JPKN"
                            class="h-16 w-auto object-contain"
                          />
                        </div>

                        <div class="flex-1 flex justify-end">
                          <div class="text-gray-700 font-bold">
                            {@analisis_pdf_data.document_id}
                          </div>
                        </div>
                      </div>

                      <h2 class="text-center font-bold text-gray-900 mb-6 uppercase tracking-wide leading-tight">
                        BORANG VERIFIKASI SPESIFIKASI APLIKASI
                      </h2>
                    </div>

                    <div class="mb-6">
                      <table class="w-full border-collapse border border-gray-800">
                        <tbody>
                          <tr class="border-b border-gray-800">
                            <td
                              class="px-2 py-1.5 font-semibold text-gray-900 bg-gray-100 border-r border-gray-800"
                              style="width: 30%;"
                            >
                              Nama Projek
                            </td>

                            <td class="px-2 py-1.5 border border-gray-800 text-black">
                              {@analisis_pdf_data.nama_projek}
                            </td>
                          </tr>

                          <tr class="border-b border-gray-800">
                            <td class="px-2 py-1.5 font-semibold text-gray-900 bg-gray-100 border-r border-gray-800">
                              Nama Agensi
                            </td>

                            <td class="px-2 py-1.5 border border-gray-800 text-black">
                              {@analisis_pdf_data.nama_agensi}
                            </td>
                          </tr>

                          <tr class="border-b border-gray-800">
                            <td class="px-2 py-1.5 font-semibold text-gray-900 bg-gray-100 border-r border-gray-800">
                              Versi
                            </td>

                            <td class="px-2 py-1.5 border border-gray-800 text-black">
                              {@analisis_pdf_data.versi}
                            </td>
                          </tr>

                          <tr class="border-b border-gray-800">
                            <td class="px-2 py-1.5 font-semibold text-gray-900 bg-gray-100 border-r border-gray-800">
                              Tarikh Semakan (jika ada)
                            </td>

                            <td class="px-2 py-1.5 border border-gray-800 text-black">
                              {@analisis_pdf_data.tarikh_semakan}
                            </td>
                          </tr>

                          <tr>
                            <td class="px-2 py-1.5 font-semibold text-gray-900 bg-gray-100 border-r border-gray-800">
                              Rujukan Perubahan (jika ada)
                            </td>

                            <td class="px-2 py-1.5 border border-gray-800 text-black">
                              {@analisis_pdf_data.rujukan_perubahan}
                            </td>
                          </tr>
                        </tbody>
                      </table>
                    </div>

                    <div class="mb-6">
                      <h3 class="font-bold text-gray-900 mb-2 uppercase">
                        SPESIFIKASI APLIKASI YANG AKAN DIBANGUNKAN
                      </h3>

                      <p class="text-gray-700 mb-2">
                        Nyatakan secara terperinci spesifikasi aplikasi yang akan dibangunkan seperti bilangan modul (nyatakan modul-modul terlibat), fungsi dan sebagainya.
                      </p>

                      <div class="space-y-4 mt-4">
                        <%= for module <- @analisis_pdf_data.modules do %>
                          <div class="mb-4">
                            <div class="mb-2">
                              <strong class="text-gray-900 font-bold">
                                {module.number}. {module.name}
                              </strong>
                            </div>

                            <div class="ml-6 space-y-2">
                              <%= for {func, index} <- Enum.with_index(module.functions) do %>
                                <div class="mb-1">
                                  <span class="text-gray-700 font-medium">
                                    {Enum.at(
                                      ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j"],
                                      index
                                    )}. {func.name}
                                  </span>
                                  <%= if length(func.sub_functions) > 0 do %>
                                    <div class="ml-4 mt-1">
                                      <%= for sub_func <- func.sub_functions do %>
                                        <div class="text-gray-600">• {sub_func.name}</div>
                                      <% end %>
                                    </div>
                                  <% end %>
                                </div>
                              <% end %>
                            </div>
                          </div>
                        <% end %>
                      </div>

                      <p class="text-gray-600 mt-4 italic">
                        **spesifikasi aplikasi adalah mengikut kajian yang telah dibuat
                      </p>
                    </div>

                    <div class="mt-8">
                      <div class="grid grid-cols-2 gap-6">
                        <div>
                          <h4 class="font-bold text-gray-900 mb-2">Dipersetujui Oleh:</h4>

                          <p class="text-gray-700 mb-3 font-semibold">Pemohon</p>

                          <div class="space-y-3">
                            <div>
                              <p class="text-gray-600 mb-1">(Nama)</p>

                              <div class="h-8 text-black">
                                {@analisis_pdf_data.approved_by_name}
                              </div>
                            </div>

                            <div>
                              <p class="text-gray-600 mb-1">Jawatan:</p>

                              <div class="h-8 text-black">
                                {@analisis_pdf_data.approved_by_position}
                              </div>
                            </div>

                            <div>
                              <p class="text-gray-600 mb-1">Tarikh:</p>

                              <div class="h-8 text-black">
                                {@analisis_pdf_data.approved_by_date}
                              </div>
                            </div>
                          </div>
                        </div>

                        <div>
                          <h4 class="font-bold text-gray-900 mb-2">Disediakan Oleh:</h4>

                          <p class="text-gray-700 mb-3 font-semibold">
                            Pengurus Projek / Pembangun
                          </p>

                          <div class="space-y-3">
                            <div>
                              <p class="text-gray-600 mb-1">(Nama)</p>

                              <div class="h-8 text-black" style="color: #000;">
                                {@analisis_pdf_data.prepared_by_name}
                              </div>
                            </div>

                            <div>
                              <p class="text-gray-600 mb-1">Jawatan:</p>

                              <div class="h-8 text-black" style="color: #000;">
                                {@analisis_pdf_data.prepared_by_position}
                              </div>
                            </div>

                            <div>
                              <p class="text-gray-600 mb-1">Tarikh:</p>

                              <div class="h-8 text-black" style="color: #000;">
                                {@analisis_pdf_data.prepared_by_date}
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% else %>
                    <div class="text-sm text-gray-600">
                      Tiada data Analisis dan Rekabentuk untuk dipaparkan.
                    </div>
                  <% end %>
                </div>
              </div>
            <% @current_tab == "Jadual Projek" -> %>
              <div class="space-y-6">
                <div class="flex justify-end gap-3 mb-4">
                  <.link
                    navigate={~p"/jadual-projek"}
                    class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors duration-200 shadow-sm hover:shadow"
                  >
                    <.icon name="hero-calendar-days" class="w-5 h-5" />
                    <span>Halaman Penuh</span>
                  </.link>
                </div>

                <%= if @jadual_gantt_data && length(@jadual_gantt_data.projects) > 0 do %>
                  <%!-- Gantt Chart Section --%>
                  <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden mb-6">
                    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border-b border-gray-200 px-6 py-4">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                          <div class="w-2 h-2 rounded-full bg-blue-600"></div>

                          <h2 class="text-xl font-bold text-gray-900">Gantt Chart Projek</h2>
                        </div>

                        <div class="text-sm text-gray-600">
                          <span class="font-semibold">Tempoh:</span> {Calendar.strftime(
                            @jadual_gantt_data.min_date,
                            "%d/%m/%Y"
                          )} - {Calendar.strftime(@jadual_gantt_data.max_date, "%d/%m/%Y")}
                        </div>
                      </div>
                    </div>

                    <div class="p-6 overflow-x-auto">
                      <div class="mb-4" style="min-width: 100%;">
                        <div
                          class="flex border-b-2 border-gray-300 pb-2"
                          style="min-width: 800px;"
                        >
                          <div class="w-64 flex-shrink-0 font-semibold text-gray-700">
                            Nama Projek
                          </div>

                          <div class="flex-1 relative">
                            <div class="flex justify-between text-xs text-gray-600">
                              <%= for month <- @jadual_month_labels do %>
                                <div class="text-center" style="width: {month.width_percent}%;">
                                  <div class="font-semibold">{month.month}</div>

                                  <div class="text-gray-500">{month.year}</div>
                                </div>
                              <% end %>
                            </div>
                          </div>
                        </div>
                      </div>

                      <%= for project <- @jadual_gantt_data.projects do %>
                        <div class="flex items-center h-12" style="min-width: 800px;">
                          <div class="w-64 flex-shrink-0 pr-4">
                            <div class="font-medium text-gray-900 truncate" title={project.nama}>
                              {project.nama}
                            </div>

                            <div class="text-xs text-gray-500">
                              {project.fasa || "-"} • {project.status || "-"}
                            </div>
                          </div>

                          <div class="flex-1 relative h-full">
                            <div class="relative h-full">
                              <div
                                class="absolute h-6 rounded-md opacity-20"
                                style={"left: #{project.start_percent}%; width: #{project.width_percent}%; background-color: #{@jadual_get_status_color.(project.status)};"}
                              >
                              </div>

                              <div
                                class="absolute h-6 rounded-md transition-all duration-300"
                                style={[
                                  "left: #{project.start_percent}%; width: #{project.width_percent}%;",
                                  "background: linear-gradient(to right, #{@jadual_get_status_color.(project.status)} #{project.progress}%, #{@jadual_get_status_color.(project.status)}40 #{project.progress}%);",
                                  "border: 2px solid #{@jadual_get_status_color.(project.status)};"
                                ]}
                                title={"#{project.nama} - Kemajuan: #{project.progress}%"}
                              >
                                <div class="absolute inset-0 flex items-center justify-center">
                                  <span class="text-xs font-semibold text-white drop-shadow-md px-2 truncate">
                                    {project.progress}%
                                  </span>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  </div>
                  <%!-- Timeline View Section --%>
                  <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
                    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border-b border-gray-200 px-6 py-4">
                      <div class="flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-indigo-600"></div>

                        <h2 class="text-xl font-bold text-gray-900">Timeline Projek</h2>
                      </div>
                    </div>

                    <div class="p-6">
                      <%= for project <- @jadual_gantt_data.projects do %>
                        <div
                          class="border-l-4 pl-6 pb-6"
                          style={"border-color: #{@jadual_get_status_color.(project.status)};"}
                        >
                          <div class="flex items-start justify-between mb-2">
                            <div class="flex-1">
                              <h3 class="text-lg font-semibold text-gray-900 mb-1">
                                {project.nama}
                              </h3>

                              <div class="flex items-center gap-4 text-sm text-gray-600 mb-2">
                                <span class="flex items-center gap-1">
                                  <.icon name="hero-calendar" class="w-4 h-4" /> {Calendar.strftime(
                                    project.tarikh_mula,
                                    "%d %b %Y"
                                  )} - {Calendar.strftime(project.tarikh_siap, "%d %b %Y")}
                                </span>
                                <%= if project.pengurus_projek do %>
                                  <span class="flex items-center gap-1">
                                    <.icon name="hero-user" class="w-4 h-4" /> {project.pengurus_projek}
                                  </span>
                                <% end %>
                              </div>
                            </div>

                            <div class="flex items-center gap-2">
                              <span class={[
                                "px-3 py-1 rounded-full text-xs font-semibold",
                                @jadual_get_status_badge_class.(project.status)
                              ]}>
                                {project.status}
                              </span>
                              <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-semibold">
                                {project.fasa || "-"}
                              </span>
                            </div>
                          </div>

                          <div class="mb-3">
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-sm font-medium text-gray-700">
                                Kemajuan Projek
                              </span>
                              <span class="text-sm font-bold text-gray-900">
                                {project.progress}%
                              </span>
                            </div>

                            <div class="w-full bg-gray-200 rounded-full h-3 overflow-hidden">
                              <div
                                class="h-full rounded-full transition-all duration-500"
                                style={"width: #{project.progress}%; background: linear-gradient(90deg, #{@jadual_get_status_color.(project.status)}, #{@jadual_get_status_color.(project.status)}dd);"}
                              >
                              </div>
                            </div>
                          </div>

                          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                            <div>
                              <span class="font-semibold text-gray-700">Tempoh:</span>
                              <span class="text-gray-600 ml-2">{project.duration} hari</span>
                            </div>

                            <div>
                              <span class="font-semibold text-gray-700">Baki:</span>
                              <span class="text-gray-600 ml-2">
                                {remaining_days = Date.diff(project.tarikh_siap, Date.utc_today())}
                                <%= if remaining_days > 0 do %>
                                  hari
                                <% else %>
                                  <span class="text-red-600 font-semibold">
                                    Lewat {abs(remaining_days)} hari
                                  </span>
                                <% end %>
                              </span>
                            </div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% else %>
                  <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
                    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border-b border-gray-200 px-6 py-4">
                      <h2 class="text-xl font-bold text-gray-900">Jadual Projek</h2>
                    </div>

                    <div class="p-8">
                      <div class="text-center py-12">
                        <.icon
                          name="hero-calendar-days"
                          class="w-16 h-16 text-gray-400 mb-4 mx-auto"
                        />
                        <h3 class="text-lg font-semibold text-gray-800 mb-2">Tiada Jadual</h3>

                        <p class="text-gray-600 mb-6 max-w-md mx-auto">
                          Tarikh mula dan tarikh siap projek belum ditetapkan. Sila kemaskini projek untuk menambah maklumat jadual.
                        </p>

                        <.link
                          navigate={~p"/jadual-projek"}
                          class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors"
                        >
                          <.icon name="hero-calendar-days" class="w-5 h-5" />
                          <span>Pergi ke Jadual Projek</span>
                        </.link>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% @current_tab == "Pengaturcaraan" -> %>
              <div class="space-y-6">
                <div class="flex items-center justify-between mb-2">
                  <p class="text-gray-600">
                    Senarai modul yang telah didaftarkan dalam Analisis dan Rekabentuk
                  </p>
                </div>

                <div class="mb-4 flex items-center">
                  <div class="flex items-center gap-2 bg-white rounded-lg p-1 shadow-sm border border-gray-200">
                    <button
                      phx-click="change_view"
                      phx-value-view="table"
                      class={[
                        "px-4 py-2 rounded-md text-sm font-medium transition-all duration-200 flex items-center gap-2",
                        if(@module_view_mode == "table",
                          do: "bg-blue-600 text-white shadow-sm",
                          else: "text-gray-600 hover:bg-gray-100"
                        )
                      ]}
                    >
                      <.icon name="hero-table-cells" class="w-4 h-4" /> <span>Jadual</span>
                    </button>
                    <button
                      phx-click="change_view"
                      phx-value-view="board"
                      class={[
                        "px-4 py-2 rounded-md text-sm font-medium transition-all duration-200 flex items-center gap-2",
                        if(@module_view_mode == "board",
                          do: "bg-blue-600 text-white shadow-sm",
                          else: "text-gray-600 hover:bg-gray-100"
                        )
                      ]}
                    >
                      <.icon name="hero-squares-2x2" class="w-4 h-4" /> <span>Papan</span>
                    </button>
                  </div>
                </div>

                <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                  <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-800">
                    <h2 class="text-xl font-semibold text-white">Senarai Modul</h2>

                    <p class="text-sm text-blue-100 mt-1">{@module_total_modules} Modul</p>
                  </div>

                  <%= if length(@modules) == 0 do %>
                    <div class="px-6 py-12 text-center">
                      <div class="flex flex-col items-center justify-center text-gray-400">
                        <.icon name="hero-inbox" class="w-12 h-12 mb-3" />
                        <p class="text-sm font-medium">Tiada modul didaftarkan</p>

                        <p class="text-xs mt-1">
                          Sila daftarkan modul di halaman Analisis dan Rekabentuk
                        </p>

                        <.link
                          navigate={~p"/analisis-dan-rekabentuk?project_id=#{@project.id}"}
                          class="mt-4 text-sm font-medium text-blue-600 hover:text-blue-800"
                        >
                          Pergi ke Analisis dan Rekabentuk →
                        </.link>
                      </div>
                    </div>
                  <% else %>
                    <%= cond do %>
                      <% @module_view_mode == "table" -> %>
                        <div class="overflow-x-auto">
                          <table class="w-full text-sm">
                            <thead class="bg-gray-50 border-b border-gray-200">
                              <tr>
                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-12">
                                  Bil
                                </th>

                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                                  Nama Modul
                                </th>

                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                                  Versi
                                </th>

                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                                  Keutamaan
                                </th>

                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                                  Status
                                </th>

                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                                  Tarikh Mula
                                </th>

                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                                  Tarikh Jangka Siap
                                </th>

                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                                  Fungsi Modul
                                </th>

                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                                  Catatan
                                </th>

                                <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                                  Tindakan
                                </th>
                              </tr>
                            </thead>

                            <tbody class="bg-white divide-y divide-gray-200">
                              <tr
                                :for={
                                  {module, index} <- Enum.with_index(@module_paginated_modules, 1)
                                }
                                class="hover:bg-gray-50 transition-colors duration-150"
                              >
                                <td class="px-3 py-2 text-center text-xs text-gray-600 font-medium">
                                  {(@module_page - 1) * @module_page_size + index}
                                </td>

                                <td class="px-3 py-2">
                                  <div>
                                    <div class="text-xs font-semibold text-gray-900">
                                      {module.name}
                                    </div>
                                  </div>
                                </td>

                                <td class="px-3 py-2 whitespace-nowrap">
                                  <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-gray-100 text-gray-700 text-xs font-mono font-medium">
                                    {module.version}
                                  </span>
                                </td>

                                <td class="px-3 py-2 whitespace-nowrap">
                                  <%= if module.priority && module.priority != "" do %>
                                    <span class={[
                                      "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border",
                                      case module.priority do
                                        "Sangat Tinggi" ->
                                          "bg-red-100 text-red-800 border-red-200"

                                        "Tinggi" ->
                                          "bg-orange-100 text-orange-800 border-orange-200"

                                        "Sederhana" ->
                                          "bg-yellow-100 text-yellow-800 border-yellow-200"

                                        "Rendah" ->
                                          "bg-blue-100 text-blue-800 border-blue-200"

                                        _ ->
                                          "bg-gray-100 text-gray-800 border-gray-200"
                                      end
                                    ]}>
                                      {module.priority}
                                    </span>
                                  <% end %>
                                </td>

                                <td class="px-3 py-2 whitespace-nowrap">
                                  <span class={[
                                    "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border",
                                    case module.status do
                                      "Belum Mula" ->
                                        "bg-gray-100 text-gray-700 border-gray-200"

                                      "Sedang Dibangunkan" ->
                                        "bg-blue-100 text-blue-800 border-blue-200"

                                      "Selesai" ->
                                        "bg-green-100 text-green-800 border-green-200"

                                      "Dalam Ujian" ->
                                        "bg-purple-100 text-purple-800 border-purple-200"

                                      _ ->
                                        "bg-gray-100 text-gray-700 border-gray-200"
                                    end
                                  ]}>
                                    <.icon
                                      name={
                                        case module.status do
                                          "Belum Mula" -> "hero-clock"
                                          "Sedang Dibangunkan" -> "hero-arrow-path"
                                          "Selesai" -> "hero-check-circle"
                                          "Dalam Ujian" -> "hero-beaker"
                                          _ -> "hero-information-circle"
                                        end
                                      }
                                      class="w-3 h-3 mr-1"
                                    /> {module.status}
                                  </span>
                                </td>

                                <td class="px-3 py-2 whitespace-nowrap">
                                  <%= if module.tarikh_mula do %>
                                    <div class="flex items-center gap-1.5">
                                      <.icon
                                        name="hero-calendar-days"
                                        class="w-3.5 h-3.5 text-gray-400"
                                      />
                                      <span class="text-xs text-gray-700">
                                        {Calendar.strftime(module.tarikh_mula, "%d/%m/%Y")}
                                      </span>
                                    </div>
                                  <% end %>
                                </td>

                                <td class="px-3 py-2 whitespace-nowrap">
                                  <%= if module.tarikh_jangka_siap do %>
                                    <div class="flex items-center gap-1.5">
                                      <.icon
                                        name="hero-calendar-days"
                                        class="w-3.5 h-3.5 text-gray-400"
                                      />
                                      <span class="text-xs text-gray-700">
                                        {Calendar.strftime(module.tarikh_jangka_siap, "%d/%m/%Y")}
                                      </span>
                                    </div>
                                  <% end %>
                                </td>

                                <td class="px-3 py-2">
                                  <%= if length(module.functions) > 0 do %>
                                    <div class="space-y-1 max-h-32 overflow-y-auto">
                                      <div
                                        :for={func <- module.functions}
                                        class="flex items-start gap-1.5 text-xs"
                                      >
                                        <div class="flex-1">
                                          <span class="text-gray-900 font-medium">
                                            {func.name}
                                          </span>
                                          <%= if length(func.sub_functions) > 0 do %>
                                            <div class="ml-3 mt-0.5 space-y-0.5">
                                              <div
                                                :for={sub_func <- func.sub_functions}
                                                class="flex items-center gap-1 text-xs text-gray-600"
                                              >
                                                <span class="text-gray-400">•</span>
                                                <span>{sub_func.name}</span>
                                              </div>
                                            </div>
                                          <% end %>
                                        </div>
                                      </div>
                                    </div>
                                  <% else %>
                                    <span class="text-xs text-gray-400 italic">-</span>
                                  <% end %>
                                </td>

                                <td class="px-3 py-2">
                                  <%= if module.catatan && module.catatan != "" do %>
                                    <div class="max-w-xs">
                                      <p class="text-xs text-gray-700 line-clamp-2">
                                        {module.catatan}
                                      </p>
                                    </div>
                                  <% end %>
                                </td>

                                <td class="px-3 py-2 whitespace-nowrap">
                                  <div class="flex items-center justify-center gap-1.5">
                                    <button
                                      type="button"
                                      phx-click="open_module_edit_modal"
                                      phx-value-module_id={module.id}
                                      class="p-1.5 text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-md transition-colors duration-200"
                                      title="Edit"
                                    >
                                      <.icon name="hero-pencil" class="w-4 h-4" />
                                    </button>
                                  </div>
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </div>

                        <div class="px-4 py-3 border-t border-gray-200 bg-gray-50 flex flex-wrap items-center justify-between gap-3">
                          <p class="text-sm text-gray-600">
                            Paparan
                            <span class="font-medium text-gray-900">
                              {(@module_page - 1) * @module_page_size + 1}
                            </span>
                            –
                            <span class="font-medium text-gray-900">
                              {min(@module_page * @module_page_size, @module_total_modules)}
                            </span>
                            daripada
                            <span class="font-medium text-gray-900">{@module_total_modules}</span>
                            modul
                          </p>

                          <nav class="flex items-center gap-1" aria-label="Pagination">
                            <button
                              phx-click="go_to_page"
                              phx-value-page={@module_page - 1}
                              disabled={@module_page <= 1}
                              class={[
                                "p-2 rounded-lg text-sm font-medium transition-all duration-200",
                                if(@module_page <= 1,
                                  do: "text-gray-400 cursor-not-allowed",
                                  else:
                                    "text-gray-700 hover:bg-white hover:shadow-sm border border-gray-200"
                                )
                              ]}
                              aria-label="Muka surat sebelumnya"
                            >
                              <.icon name="hero-chevron-left" class="w-5 h-5" />
                            </button>
                            <div class="flex items-center gap-1">
                              <%= for p <- @module_page_numbers do %>
                                <%= if p == :ellipsis do %>
                                  <span class="px-2 text-gray-400">…</span>
                                <% else %>
                                  <button
                                    phx-click="go_to_page"
                                    phx-value-page={p}
                                    class={[
                                      "min-w-[2.25rem] py-2 px-2 rounded-lg text-sm font-medium transition-all duration-200",
                                      if(p == @module_page,
                                        do: "bg-blue-600 text-white shadow-sm",
                                        else:
                                          "text-gray-700 hover:bg-white hover:shadow-sm border border-gray-200"
                                      )
                                    ]}
                                  >
                                    {p}
                                  </button>
                                <% end %>
                              <% end %>
                            </div>

                            <button
                              phx-click="go_to_page"
                              phx-value-page={@module_page + 1}
                              disabled={@module_page >= @module_total_pages}
                              class={[
                                "p-2 rounded-lg text-sm font-medium transition-all duration-200",
                                if(@module_page >= @module_total_pages,
                                  do: "text-gray-400 cursor-not-allowed",
                                  else:
                                    "text-gray-700 hover:bg-white hover:shadow-sm border border-gray-200"
                                )
                              ]}
                              aria-label="Muka surat seterusnya"
                            >
                              <.icon name="hero-chevron-right" class="w-5 h-5" />
                            </button>
                          </nav>
                        </div>
                      <% @module_view_mode == "board" -> %>
                        <div class="p-6">
                          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                            <%= for status <- ["Belum Mula", "Sedang Dibangunkan", "Dalam Ujian", "Selesai"] do %>
                              <% modules_in_status =
                                Enum.filter(@modules, fn m -> m.status == status end) %>
                              <div class="bg-gray-50 rounded-lg p-4 min-h-[200px]">
                                <div class="flex items-center justify-between mb-4">
                                  <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">
                                    {status}
                                  </h3>

                                  <span class={[
                                    "inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-semibold",
                                    case status do
                                      "Belum Mula" -> "bg-gray-200 text-gray-700"
                                      "Sedang Dibangunkan" -> "bg-blue-200 text-blue-700"
                                      "Dalam Ujian" -> "bg-purple-200 text-purple-700"
                                      "Selesai" -> "bg-green-200 text-green-700"
                                      _ -> "bg-gray-200 text-gray-700"
                                    end
                                  ]}>
                                    {length(modules_in_status)}
                                  </span>
                                </div>

                                <div class="space-y-3">
                                  <%= for module <- modules_in_status do %>
                                    <div class="bg-white rounded-lg p-3 shadow-sm border border-gray-200 hover:shadow-md transition-shadow cursor-pointer">
                                      <div class="flex items-start justify-between mb-2">
                                        <div class="flex-1">
                                          <div class="flex items-center gap-2 mb-1">
                                            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-blue-100 text-blue-700 font-semibold text-xs">
                                              {module.number}
                                            </span>
                                            <h4 class="text-sm font-semibold text-gray-900 line-clamp-1">
                                              {module.name}
                                            </h4>
                                          </div>

                                          <div class="flex items-center gap-2 mb-2 flex-wrap">
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-gray-100 text-gray-700 text-xs font-mono">
                                              {module.version}
                                            </span>
                                            <%= if module.priority && module.priority != "" do %>
                                              <span class={[
                                                "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border",
                                                case module.priority do
                                                  "Sangat Tinggi" ->
                                                    "bg-red-100 text-red-800 border-red-200"

                                                  "Tinggi" ->
                                                    "bg-orange-100 text-orange-800 border-orange-200"

                                                  "Sederhana" ->
                                                    "bg-yellow-100 text-yellow-800 border-yellow-200"

                                                  "Rendah" ->
                                                    "bg-blue-100 text-blue-800 border-blue-200"

                                                  _ ->
                                                    "bg-gray-100 text-gray-800 border-gray-200"
                                                end
                                              ]}>
                                                {module.priority}
                                              </span>
                                            <% end %>
                                          </div>

                                          <%= if module.tarikh_mula || module.tarikh_jangka_siap do %>
                                            <div class="flex items-center gap-2 text-xs text-gray-600 mb-2">
                                              <%= if module.tarikh_mula do %>
                                                <span>
                                                  {Calendar.strftime(
                                                    module.tarikh_mula,
                                                    "%d/%m/%Y"
                                                  )}
                                                </span>
                                              <% end %>

                                              <%= if module.tarikh_mula && module.tarikh_jangka_siap do %>
                                                <span>→</span>
                                              <% end %>

                                              <%= if module.tarikh_jangka_siap do %>
                                                <span>
                                                  {Calendar.strftime(
                                                    module.tarikh_jangka_siap,
                                                    "%d/%m/%Y"
                                                  )}
                                                </span>
                                              <% end %>
                                            </div>
                                          <% end %>

                                          <%= if module.catatan && module.catatan != "" do %>
                                            <p class="text-xs text-gray-600 line-clamp-2 mb-2">
                                              {module.catatan}
                                            </p>
                                          <% end %>

                                          <div class="flex items-center gap-1.5 mt-2">
                                            <button
                                              type="button"
                                              phx-click="open_module_edit_modal"
                                              phx-value-module_id={module.id}
                                              class="p-1 text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded transition-colors"
                                              title="Edit"
                                            >
                                              <.icon name="hero-pencil" class="w-3.5 h-3.5" />
                                            </button>
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                  <% end %>

                                  <%= if length(modules_in_status) == 0 do %>
                                    <div class="text-center py-8 text-gray-400 text-sm">
                                      Tiada modul
                                    </div>
                                  <% end %>
                                </div>
                              </div>
                            <% end %>
                          </div>
                        </div>
                    <% end %>
                  <% end %>
                </div>

                <%= if @module_show_edit_modal && @selected_module do %>
                  <div
                    class="fixed inset-0 z-50 overflow-y-auto"
                    role="dialog"
                    aria-modal="true"
                  >
                    <div
                      class="fixed inset-0 bg-black/60 transition-opacity"
                      aria-hidden="true"
                      phx-click="close_module_edit_modal"
                    >
                    </div>

                    <div class="flex min-h-full items-center justify-center p-4">
                      <div
                        class="relative w-full max-w-3xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all"
                        phx-click-away="close_module_edit_modal"
                      >
                        <div class="border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-5">
                          <div class="flex items-center justify-between">
                            <div>
                              <h2 class="text-2xl font-bold text-white">Kemaskini Modul</h2>

                              <p class="mt-1 text-sm text-blue-100">Edit maklumat modul</p>
                            </div>

                            <button
                              type="button"
                              phx-click="close_module_edit_modal"
                              class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50"
                              aria-label="Tutup"
                            >
                              <.icon name="hero-x-mark" class="h-6 w-6" />
                            </button>
                          </div>
                        </div>

                        <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6">
                          <div class="mb-6 pb-4 border-b border-gray-200">
                            <label class="block text-sm font-medium text-gray-500 mb-1">
                              Nama Modul
                            </label>
                            <p class="text-base font-semibold text-gray-900">
                              {@selected_module.name}
                            </p>
                          </div>

                          <.form
                            for={@module_form}
                            phx-submit="update_module"
                            id="edit-module-form-from-tab"
                            class="space-y-6"
                          >
                            <div class="space-y-5">
                              <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                  Keutamaan
                                </label>
                                <select
                                  name="module[priority]"
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 text-gray-900 bg-white"
                                  style="color: rgb(17, 24, 39);"
                                >
                                  <option
                                    value=""
                                    selected={@module_form[:priority].value in [nil, ""]}
                                    style="color: rgb(107, 114, 128);"
                                  >
                                    —
                                  </option>

                                  <option
                                    value="Sangat Tinggi"
                                    selected={@module_form[:priority].value == "Sangat Tinggi"}
                                    style="color: rgb(17, 24, 39);"
                                  >
                                    Sangat Tinggi
                                  </option>

                                  <option
                                    value="Tinggi"
                                    selected={@module_form[:priority].value == "Tinggi"}
                                    style="color: rgb(17, 24, 39);"
                                  >
                                    Tinggi
                                  </option>

                                  <option
                                    value="Sederhana"
                                    selected={@module_form[:priority].value == "Sederhana"}
                                    style="color: rgb(17, 24, 39);"
                                  >
                                    Sederhana
                                  </option>

                                  <option
                                    value="Rendah"
                                    selected={@module_form[:priority].value == "Rendah"}
                                    style="color: rgb(17, 24, 39);"
                                  >
                                    Rendah
                                  </option>
                                </select>
                              </div>

                              <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                  Status
                                </label>
                                <select
                                  name="module[status]"
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 text-gray-900 bg-white"
                                  style="color: rgb(17, 24, 39);"
                                >
                                  <option
                                    value="Belum Mula"
                                    selected={@module_form[:status].value == "Belum Mula"}
                                    style="color: rgb(17, 24, 39);"
                                  >
                                    Belum Mula
                                  </option>

                                  <option
                                    value="Sedang Dibangunkan"
                                    selected={@module_form[:status].value == "Sedang Dibangunkan"}
                                    style="color: rgb(17, 24, 39);"
                                  >
                                    Sedang Dibangunkan
                                  </option>

                                  <option
                                    value="Dalam Ujian"
                                    selected={@module_form[:status].value == "Dalam Ujian"}
                                    style="color: rgb(17, 24, 39);"
                                  >
                                    Dalam Ujian
                                  </option>

                                  <option
                                    value="Selesai"
                                    selected={@module_form[:status].value == "Selesai"}
                                    style="color: rgb(17, 24, 39);"
                                  >
                                    Selesai
                                  </option>
                                </select>
                              </div>

                              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                  <label class="block text-sm font-medium text-gray-700 mb-2">
                                    Tarikh Mula
                                  </label>
                                  <label class="relative block">
                                    <.icon
                                      name="hero-calendar-days"
                                      class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400"
                                    />
                                    <input
                                      type="date"
                                      id="module-tarikh-mula-from-tab"
                                      name="module[tarikh_mula]"
                                      value={
                                        if @module_form[:tarikh_mula] &&
                                             @module_form[:tarikh_mula].value != "",
                                           do: @module_form[:tarikh_mula].value,
                                           else: ""
                                      }
                                      phx-hook="OpenDatePicker"
                                      class="w-full pl-4 pr-9 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 text-gray-900 bg-white"
                                    />
                                  </label>
                                </div>

                                <div>
                                  <label class="block text-sm font-medium text-gray-700 mb-2">
                                    Tarikh Jangka Siap
                                  </label>
                                  <label class="relative block">
                                    <.icon
                                      name="hero-calendar-days"
                                      class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400"
                                    />
                                    <input
                                      type="date"
                                      id="module-tarikh-jangka-siap-from-tab"
                                      name="module[tarikh_jangka_siap]"
                                      value={
                                        if @module_form[:tarikh_jangka_siap] &&
                                             @module_form[:tarikh_jangka_siap].value != "",
                                           do: @module_form[:tarikh_jangka_siap].value,
                                           else: ""
                                      }
                                      phx-hook="OpenDatePicker"
                                      class="w-full pl-4 pr-9 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 text-gray-900 bg-white"
                                    />
                                  </label>
                                </div>
                              </div>

                              <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                  Catatan
                                </label>
                                <textarea
                                  name="module[catatan]"
                                  rows="4"
                                  placeholder="Masukkan catatan..."
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none text-gray-900 placeholder-gray-400 bg-white"
                                ><%= if @module_form[:catatan] && @module_form[:catatan].value, do: @module_form[:catatan].value, else: "" %></textarea>
                              </div>
                            </div>
                          </.form>
                        </div>

                        <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex justify-end gap-3">
                          <button
                            type="button"
                            phx-click="close_module_edit_modal"
                            class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium"
                          >
                            Batal
                          </button>
                          <button
                            type="submit"
                            form="edit-module-form-from-tab"
                            class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200 font-medium"
                          >
                            Simpan
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% @current_tab == "Pengurus Perubahan" -> %>
              <div class="space-y-6">
                <div class="mb-4 flex items-center justify-between">
                  <div>
                    <h3 class="text-xl font-bold text-gray-900">Pengurusan Perubahan</h3>
                    <p class="text-gray-600 text-sm">
                      Urus dan pantau permohonan perubahan sistem
                    </p>
                  </div>

                  <button
                    phx-click="open_create_modal"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 shadow-md hover:shadow-lg transition-all duration-200 font-medium text-sm"
                  >
                    <.icon name="hero-plus-circle" class="w-5 h-5" />
                    <span>Daftar Perubahan</span>
                  </button>
                </div>

                <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-200">
                  <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-800">
                    <h3 class="text-lg font-semibold text-white">Senarai Permohonan Perubahan</h3>
                  </div>

                  <%= if length(@perubahan) == 0 do %>
                    <div class="px-6 py-12 text-center">
                      <div class="flex flex-col items-center justify-center text-gray-400">
                        <.icon name="hero-inbox" class="w-12 h-12 mb-3" />
                        <p class="text-sm font-medium">Tiada permohonan perubahan</p>

                        <p class="text-xs mt-1">
                          Klik butang "Daftar Perubahan" untuk menambah permohonan baharu
                        </p>
                      </div>
                    </div>
                  <% else %>
                    <div class="overflow-x-auto">
                      <table class="w-full text-sm">
                        <thead class="bg-gray-50 border-b border-gray-200">
                          <tr>
                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-14">
                              Bil
                            </th>

                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Tajuk Perubahan
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Jenis
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Modul Terlibat
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Tarikh Dibuat
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Justifikasi
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Kesan
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Catatan
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Tindakan
                            </th>
                          </tr>
                        </thead>

                        <tbody class="bg-white divide-y divide-gray-200">
                          <tr
                            :for={{perubahan, bil} <- Enum.with_index(@perubahan, 1)}
                            class="hover:bg-gray-50 transition-colors duration-150"
                          >
                            <td class="px-3 py-2 text-center text-gray-600 font-medium">{bil}</td>

                            <td class="px-3 py-2">
                              <div class="text-xs font-semibold text-gray-900">
                                {perubahan.tajuk}
                              </div>
                            </td>

                            <td class="px-3 py-2 whitespace-nowrap">
                              <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-purple-100 text-purple-700 text-xs font-medium">
                                {perubahan.jenis}
                              </span>
                            </td>

                            <td class="px-3 py-2">
                              <span class="text-xs text-gray-700">
                                {perubahan.modul_terlibat}
                              </span>
                            </td>

                            <td class="px-3 py-2 whitespace-nowrap">
                              <div class="flex items-center gap-1.5 justify-center">
                                <.icon
                                  name="hero-calendar-days"
                                  class="w-3.5 h-3.5 text-gray-400"
                                />
                                <span class="text-xs text-gray-700">
                                  {Calendar.strftime(perubahan.tarikh_dibuat, "%d/%m/%Y")}
                                </span>
                              </div>
                            </td>

                            <td class="px-3 py-2">
                              <%= if perubahan.justifikasi do %>
                                <div class="max-w-xs">
                                  <p class="text-xs text-gray-700 line-clamp-2">
                                    {perubahan.justifikasi}
                                  </p>
                                </div>
                              <% else %>
                                <span class="text-xs text-gray-400 italic">-</span>
                              <% end %>
                            </td>

                            <td class="px-3 py-2">
                              <%= if perubahan.kesan do %>
                                <div class="max-w-xs">
                                  <p class="text-xs text-gray-700 line-clamp-2">
                                    {perubahan.kesan}
                                  </p>
                                </div>
                              <% else %>
                                <span class="text-xs text-gray-400 italic">-</span>
                              <% end %>
                            </td>

                            <td class="px-3 py-2">
                              <%= if perubahan.catatan do %>
                                <div class="max-w-xs">
                                  <p class="text-xs text-gray-700 line-clamp-2">
                                    {perubahan.catatan}
                                  </p>
                                </div>
                              <% else %>
                                <span class="text-xs text-gray-400 italic">-</span>
                              <% end %>
                            </td>

                            <td class="px-3 py-2 whitespace-nowrap">
                              <div class="flex items-center justify-center gap-1.5">
                                <button
                                  type="button"
                                  phx-click="open_view_modal"
                                  phx-value-perubahan_id={perubahan.id}
                                  class="p-1.5 text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-md transition-colors duration-200"
                                  title="Lihat"
                                >
                                  <.icon name="hero-eye" class="w-4 h-4" />
                                </button>

                                <button
                                  type="button"
                                  phx-click="open_edit_modal"
                                  phx-value-perubahan_id={perubahan.id}
                                  class="p-1.5 text-green-600 hover:text-green-800 hover:bg-green-50 rounded-md transition-colors duration-200"
                                  title="Kemaskini"
                                >
                                  <.icon name="hero-pencil-square" class="w-4 h-4" />
                                </button>
                              </div>
                            </td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  <% end %>
                </div>
              </div>
              <%!-- View Modal (Pengurus Perubahan tab) - paparan sahaja --%>
              <%= if @show_view_modal && @selected_perubahan do %>
                <div
                  class="fixed inset-0 z-50 overflow-y-auto"
                  role="dialog"
                  aria-modal="true"
                >
                  <%!-- Backdrop: tutup modal hanya bila klik pada kawasan gelap --%>
                  <div
                    class="fixed inset-0 bg-black/60 transition-opacity z-40"
                    aria-hidden="true"
                    phx-click="close_view_modal"
                  >
                  </div>

                  <%!-- Modal container: klik dalam kotak modal tidak menutup --%>
                  <div class="flex min-h-full items-center justify-center p-4 relative z-50 pointer-events-none">
                    <div class="relative w-full max-w-4xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all pointer-events-auto">
                      <%!-- Modal header --%>
                      <div class="border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-5">
                        <div class="flex items-center justify-between">
                          <div>
                            <h2 class="text-2xl font-bold text-white">
                              Butiran Permohonan Perubahan
                            </h2>

                            <p class="mt-1 text-sm text-blue-100">
                              Maklumat lengkap permohonan perubahan
                            </p>
                          </div>

                          <button
                            type="button"
                            phx-click="close_view_modal"
                            class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50"
                            aria-label="Tutup"
                          >
                            <.icon name="hero-x-mark" class="h-6 w-6" />
                          </button>
                        </div>
                      </div>
                      <%!-- Modal body --%>
                      <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6">
                        <div class="space-y-6">
                          <%!-- Basic Information --%>
                          <div class="space-y-4">
                            <div class="border-b border-gray-200 pb-2">
                              <h3 class="text-lg font-semibold text-gray-900">Maklumat Asas</h3>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                              <div class="md:col-span-2">
                                <label class="block text-sm font-medium text-gray-800 mb-1">
                                  Tajuk Perubahan
                                </label>
                                <p class="text-sm text-gray-900 font-semibold">
                                  {@selected_perubahan.tajuk}
                                </p>
                              </div>

                              <div>
                                <label class="block text-sm font-medium text-gray-800 mb-1">
                                  Jenis
                                </label>
                                <span class="inline-flex items-center px-3 py-1 rounded-md bg-purple-100 text-purple-700 text-sm font-medium">
                                  {@selected_perubahan.jenis}
                                </span>
                              </div>

                              <div>
                                <label class="block text-sm font-medium text-gray-800 mb-1">
                                  Modul Terlibat
                                </label>
                                <p class="text-sm text-gray-900">
                                  {@selected_perubahan.modul_terlibat}
                                </p>
                              </div>

                              <div>
                                <label class="block text-sm font-medium text-gray-800 mb-1">
                                  Status
                                </label>
                                <span class={[
                                  "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium border",
                                  case @selected_perubahan.status do
                                    "Dalam Semakan" ->
                                      "bg-yellow-100 text-yellow-800 border-yellow-200"

                                    "Diluluskan" ->
                                      "bg-green-100 text-green-800 border-green-200"

                                    "Ditolak" ->
                                      "bg-red-100 text-red-800 border-red-200"

                                    "Dalam Pelaksanaan" ->
                                      "bg-blue-100 text-blue-800 border-blue-200"

                                    "Selesai" ->
                                      "bg-gray-100 text-gray-800 border-gray-200"

                                    _ ->
                                      "bg-gray-100 text-gray-800 border-gray-200"
                                  end
                                ]}>
                                  <.icon
                                    name={
                                      case @selected_perubahan.status do
                                        "Dalam Semakan" -> "hero-clock"
                                        "Diluluskan" -> "hero-check-circle"
                                        "Ditolak" -> "hero-x-circle"
                                        "Dalam Pelaksanaan" -> "hero-arrow-path"
                                        "Selesai" -> "hero-check-badge"
                                        _ -> "hero-information-circle"
                                      end
                                    }
                                    class="w-4 h-4 mr-1"
                                  /> {@selected_perubahan.status}
                                </span>
                              </div>

                              <div>
                                <label class="block text-sm font-medium text-gray-800 mb-1">
                                  Keutamaan
                                </label>
                                <span class={[
                                  "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium border",
                                  case @selected_perubahan.keutamaan do
                                    "Sangat Tinggi" ->
                                      "bg-red-100 text-red-800 border-red-200"

                                    "Tinggi" ->
                                      "bg-orange-100 text-orange-800 border-orange-200"

                                    "Sederhana" ->
                                      "bg-yellow-100 text-yellow-800 border-yellow-200"

                                    "Rendah" ->
                                      "bg-blue-100 text-blue-800 border-blue-200"

                                    _ ->
                                      "bg-gray-100 text-gray-800 border-gray-200"
                                  end
                                ]}>
                                  <.icon
                                    name={
                                      case @selected_perubahan.keutamaan do
                                        "Sangat Tinggi" -> "hero-exclamation-triangle"
                                        "Tinggi" -> "hero-arrow-up"
                                        "Sederhana" -> "hero-minus"
                                        "Rendah" -> "hero-arrow-down"
                                        _ -> "hero-information-circle"
                                      end
                                    }
                                    class="w-4 h-4 mr-1"
                                  /> {@selected_perubahan.keutamaan}
                                </span>
                              </div>
                            </div>
                          </div>
                          <%!-- Timeline --%>
                          <div class="space-y-4">
                            <div class="border-b border-gray-200 pb-2">
                              <h3 class="text-lg font-semibold text-gray-900">Jadual</h3>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                              <div>
                                <label class="block text-sm font-medium text-gray-800 mb-1">
                                  Tarikh Dibuat
                                </label>
                                <div class="flex items-center gap-2">
                                  <.icon name="hero-calendar-days" class="w-4 h-4 text-gray-400" />
                                  <span class="text-sm text-gray-900">
                                    {Calendar.strftime(
                                      @selected_perubahan.tarikh_dibuat,
                                      "%d/%m/%Y"
                                    )}
                                  </span>
                                </div>
                              </div>

                              <div>
                                <label class="block text-sm font-medium text-gray-800 mb-1">
                                  Tarikh Dijangka Siap
                                </label>
                                <div class="flex items-center gap-2">
                                  <.icon name="hero-calendar-days" class="w-4 h-4 text-gray-400" />
                                  <span class="text-sm text-gray-900">
                                    <%= if @selected_perubahan.tarikh_dijangka_siap do %>
                                      {Calendar.strftime(
                                        @selected_perubahan.tarikh_dijangka_siap,
                                        "%d/%m/%Y"
                                      )}
                                    <% else %>
                                      -
                                    <% end %>
                                  </span>
                                </div>
                              </div>
                            </div>
                          </div>
                          <%!-- Justification --%>
                          <%= if @selected_perubahan.justifikasi do %>
                            <div class="space-y-4">
                              <div class="border-b border-gray-200 pb-2">
                                <h3 class="text-lg font-semibold text-gray-900">Justifikasi</h3>
                              </div>

                              <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                                <p class="text-sm text-gray-700 whitespace-pre-wrap">
                                  {@selected_perubahan.justifikasi}
                                </p>
                              </div>
                            </div>
                          <% end %>
                          <%!-- Impact --%>
                          <%= if @selected_perubahan.kesan do %>
                            <div class="space-y-4">
                              <div class="border-b border-gray-200 pb-2">
                                <h3 class="text-lg font-semibold text-gray-900">Kesan</h3>
                              </div>

                              <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                                <p class="text-sm text-gray-700 whitespace-pre-wrap">
                                  {@selected_perubahan.kesan}
                                </p>
                              </div>
                            </div>
                          <% end %>
                          <%!-- Notes --%>
                          <%= if @selected_perubahan.catatan do %>
                            <div class="space-y-4">
                              <div class="border-b border-gray-200 pb-2">
                                <h3 class="text-lg font-semibold text-gray-900">Catatan</h3>
                              </div>

                              <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                                <p class="text-sm text-gray-700 whitespace-pre-wrap">
                                  {@selected_perubahan.catatan}
                                </p>
                              </div>
                            </div>
                          <% end %>
                        </div>
                      </div>
                      <%!-- Modal footer --%>
                      <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex justify-end gap-3">
                        <button
                          type="button"
                          phx-click="close_view_modal"
                          class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium"
                        >
                          Tutup
                        </button>
                        <button
                          type="button"
                          phx-click="open_edit_modal"
                          phx-value-perubahan_id={@selected_perubahan.id}
                          class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200 font-medium"
                        >
                          Edit
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>

              <%!-- Create Modal (Pengurusan Perubahan) --%>
              <%= if @show_create_modal do %>
                <div
                  class="fixed inset-0 z-50 overflow-y-auto"
                  role="dialog"
                  aria-modal="true"
                >
                  <%!-- Backdrop: tutup modal hanya bila klik pada kawasan gelap --%>
                  <div
                    class="fixed inset-0 bg-black/60 transition-opacity z-40"
                    aria-hidden="true"
                    phx-click="close_create_modal"
                  >
                  </div>
                  <%!-- Modal container: klik dalam kotak modal tidak menutup --%>
                  <div class="flex min-h-full items-center justify-center p-4 relative z-50 pointer-events-none">
                    <div class="relative w-full max-w-3xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all pointer-events-auto">
                      <%!-- Modal header --%>
                      <div class="border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-5">
                        <div class="flex items-center justify-between">
                          <div>
                            <h2 class="text-2xl font-bold text-white">
                              Daftar Permohonan Perubahan
                            </h2>

                            <p class="mt-1 text-sm text-blue-100">
                              Isi maklumat permohonan perubahan baharu
                            </p>
                          </div>

                          <button
                            type="button"
                            phx-click="close_create_modal"
                            class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50"
                            aria-label="Tutup"
                          >
                            <.icon name="hero-x-mark" class="h-6 w-6" />
                          </button>
                        </div>
                      </div>
                      <%!-- Modal body --%>
                      <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6">
                        <.form
                          for={@form}
                          phx-change="validate_perubahan"
                          phx-submit="create_perubahan"
                          id="create-perubahan-form"
                          class="space-y-6"
                        >
                          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="md:col-span-2">
                              <.input
                                field={@form[:tajuk]}
                                type="text"
                                label="Tajuk Perubahan"
                                required
                                placeholder="Masukkan tajuk perubahan"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                              />
                            </div>

                            <div>
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Jenis
                              </label>
                              <select
                                name="perubahan[jenis]"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                              >
                                <option value="">Pilih jenis</option>

                                <option
                                  value="Perubahan Fungsian"
                                  selected={@form[:jenis].value == "Perubahan Fungsian"}
                                >
                                  Perubahan Fungsian
                                </option>

                                <option
                                  value="Pembaikan Bug"
                                  selected={@form[:jenis].value == "Pembaikan Bug"}
                                >
                                  Pembaikan Bug
                                </option>

                                <option
                                  value="Penambahbaikan"
                                  selected={@form[:jenis].value == "Penambahbaikan"}
                                >
                                  Penambahbaikan
                                </option>

                                <option
                                  value="Peningkatan Keselamatan"
                                  selected={@form[:jenis].value == "Peningkatan Keselamatan"}
                                >
                                  Peningkatan Keselamatan
                                </option>

                                <option
                                  value="Modul Baharu"
                                  selected={@form[:jenis].value == "Modul Baharu"}
                                >
                                  Modul Baharu
                                </option>
                              </select>
                            </div>

                            <div>
                              <.input
                                field={@form[:modul_terlibat]}
                                type="text"
                                label="Modul Terlibat"
                                required
                                placeholder="Masukkan nama modul"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                              />
                            </div>

                            <div class="fieldset mb-2">
                              <label
                                for={@form[:tarikh_dibuat].id}
                                class="block text-sm font-medium text-gray-800 mb-1"
                              >
                                Tarikh Dibuat
                              </label>
                              <div class="relative">
                                <input
                                  type="date"
                                  id={@form[:tarikh_dibuat].id}
                                  name="perubahan[tarikh_dibuat]"
                                  value={
                                    Phoenix.HTML.Form.normalize_value(
                                      "date",
                                      @form[:tarikh_dibuat].value
                                    )
                                  }
                                  required
                                  class="w-full px-4 py-2.5 pr-10 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>

                              <%= for msg <- @form[:tarikh_dibuat].errors do %>
                                <p class="mt-1.5 flex gap-2 items-center text-sm text-red-600">
                                  <.icon name="hero-exclamation-circle" class="size-5 shrink-0" /> {msg}
                                </p>
                              <% end %>
                            </div>

                            <div class="fieldset mb-2">
                              <label
                                for={@form[:tarikh_dijangka_siap].id}
                                class="block text-sm font-medium text-gray-800 mb-1"
                              >
                                Tarikh Dijangka Siap
                              </label>
                              <div class="relative">
                                <input
                                  type="date"
                                  id={@form[:tarikh_dijangka_siap].id}
                                  name="perubahan[tarikh_dijangka_siap]"
                                  value={
                                    Phoenix.HTML.Form.normalize_value(
                                      "date",
                                      @form[:tarikh_dijangka_siap].value
                                    )
                                  }
                                  required
                                  class="w-full px-4 py-2.5 pr-10 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>

                              <%= for msg <- @form[:tarikh_dijangka_siap].errors do %>
                                <p class="mt-1.5 flex gap-2 items-center text-sm text-red-600">
                                  <.icon name="hero-exclamation-circle" class="size-5 shrink-0" /> {msg}
                                </p>
                              <% end %>
                            </div>

                            <div>
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Keutamaan
                              </label>
                              <select
                                name="perubahan[keutamaan]"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                              >
                                <option
                                  value="Sangat Tinggi"
                                  selected={@form[:keutamaan].value == "Sangat Tinggi"}
                                >
                                  Sangat Tinggi
                                </option>

                                <option
                                  value="Tinggi"
                                  selected={@form[:keutamaan].value == "Tinggi"}
                                >
                                  Tinggi
                                </option>

                                <option
                                  value="Sederhana"
                                  selected={@form[:keutamaan].value == "Sederhana"}
                                >
                                  Sederhana
                                </option>

                                <option
                                  value="Rendah"
                                  selected={@form[:keutamaan].value == "Rendah"}
                                >
                                  Rendah
                                </option>
                              </select>
                            </div>

                            <div class="md:col-span-2">
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Justifikasi
                              </label>
                              <textarea
                                name="perubahan[justifikasi]"
                                rows="3"
                                placeholder="Masukkan justifikasi perubahan..."
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none"
                              ><%= if @form[:justifikasi] && @form[:justifikasi].value, do: @form[:justifikasi].value, else: "" %></textarea>
                            </div>

                            <div class="md:col-span-2">
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Kesan
                              </label>
                              <textarea
                                name="perubahan[kesan]"
                                rows="3"
                                placeholder="Masukkan kesan perubahan..."
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none"
                              ><%= if @form[:kesan] && @form[:kesan].value, do: @form[:kesan].value, else: "" %></textarea>
                            </div>

                            <div class="md:col-span-2">
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Catatan
                              </label>
                              <textarea
                                name="perubahan[catatan]"
                                rows="3"
                                placeholder="Masukkan catatan..."
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none"
                              ><%= if @form[:catatan] && @form[:catatan].value, do: @form[:catatan].value, else: "" %></textarea>
                            </div>
                          </div>
                        </.form>
                      </div>
                      <%!-- Modal footer --%>
                      <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex justify-end gap-3">
                        <button
                          type="button"
                          phx-click="close_create_modal"
                          class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium"
                        >
                          Batal
                        </button>
                        <button
                          type="submit"
                          form="create-perubahan-form"
                          class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200 font-medium"
                        >
                          Daftar Perubahan
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>

              <%!-- Edit Modal (Pengurusan Perubahan) --%>
              <%= if @show_edit_modal && @selected_perubahan do %>
                <div
                  class="fixed inset-0 z-50 overflow-y-auto"
                  role="dialog"
                  aria-modal="true"
                >
                  <%!-- Backdrop: tutup modal hanya bila klik pada kawasan gelap --%>
                  <div
                    class="fixed inset-0 bg-black/60 transition-opacity z-40"
                    aria-hidden="true"
                    phx-click="close_edit_modal"
                  >
                  </div>
                  <%!-- Modal container: klik dalam kotak modal tidak menutup --%>
                  <div class="flex min-h-full items-center justify-center p-4 relative z-50 pointer-events-none">
                    <div class="relative w-full max-w-3xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all pointer-events-auto">
                      <%!-- Modal header --%>
                      <div class="border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-5">
                        <div class="flex items-center justify-between">
                          <div>
                            <h2 class="text-2xl font-bold text-white">
                              Kemaskini Permohonan Perubahan
                            </h2>

                            <p class="mt-1 text-sm text-blue-100">
                              Edit maklumat permohonan perubahan
                            </p>
                          </div>

                          <button
                            type="button"
                            phx-click="close_edit_modal"
                            class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50"
                            aria-label="Tutup"
                          >
                            <.icon name="hero-x-mark" class="h-6 w-6" />
                          </button>
                        </div>
                      </div>
                      <%!-- Modal body --%>
                      <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6">
                        <.form
                          for={@form}
                          phx-change="validate_perubahan"
                          phx-submit="update_perubahan"
                          id="edit-perubahan-form"
                          class="space-y-6"
                        >
                          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="md:col-span-2">
                              <.input
                                field={@form[:tajuk]}
                                type="text"
                                label="Tajuk Perubahan"
                                required
                                placeholder="Masukkan tajuk perubahan"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                              />
                            </div>

                            <div>
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Jenis
                              </label>
                              <select
                                name="perubahan[jenis]"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                              >
                                <option value="">Pilih jenis</option>

                                <option
                                  value="Perubahan Fungsian"
                                  selected={@form[:jenis].value == "Perubahan Fungsian"}
                                >
                                  Perubahan Fungsian
                                </option>

                                <option
                                  value="Pembaikan Bug"
                                  selected={@form[:jenis].value == "Pembaikan Bug"}
                                >
                                  Pembaikan Bug
                                </option>

                                <option
                                  value="Penambahbaikan"
                                  selected={@form[:jenis].value == "Penambahbaikan"}
                                >
                                  Penambahbaikan
                                </option>

                                <option
                                  value="Peningkatan Keselamatan"
                                  selected={@form[:jenis].value == "Peningkatan Keselamatan"}
                                >
                                  Peningkatan Keselamatan
                                </option>

                                <option
                                  value="Modul Baharu"
                                  selected={@form[:jenis].value == "Modul Baharu"}
                                >
                                  Modul Baharu
                                </option>
                              </select>
                            </div>

                            <div>
                              <.input
                                field={@form[:modul_terlibat]}
                                type="text"
                                label="Modul Terlibat"
                                required
                                placeholder="Masukkan nama modul"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                              />
                            </div>

                            <div class="fieldset mb-2">
                              <label
                                for={@form[:tarikh_dibuat].id}
                                class="block text-sm font-medium text-gray-800 mb-1"
                              >
                                Tarikh Dibuat
                              </label>
                              <div class="relative">
                                <input
                                  type="date"
                                  id={@form[:tarikh_dibuat].id}
                                  name="perubahan[tarikh_dibuat]"
                                  value={
                                    Phoenix.HTML.Form.normalize_value(
                                      "date",
                                      @form[:tarikh_dibuat].value
                                    )
                                  }
                                  required
                                  class="w-full px-4 py-2.5 pr-10 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all duration-200"
                                />
                              </div>

                              <%= for msg <- @form[:tarikh_dibuat].errors do %>
                                <p class="mt-1.5 flex gap-2 items-center text-sm text-red-600">
                                  <.icon name="hero-exclamation-circle" class="size-5 shrink-0" /> {msg}
                                </p>
                              <% end %>
                            </div>

                            <div class="fieldset mb-2">
                              <label
                                for={@form[:tarikh_dijangka_siap].id}
                                class="block text-sm font-medium text-gray-800 mb-1"
                              >
                                Tarikh Dijangka Siap
                              </label>
                              <div class="relative">
                                <input
                                  type="date"
                                  id={@form[:tarikh_dijangka_siap].id}
                                  name="perubahan[tarikh_dijangka_siap]"
                                  value={
                                    Phoenix.HTML.Form.normalize_value(
                                      "date",
                                      @form[:tarikh_dijangka_siap].value
                                    )
                                  }
                                  required
                                  class="w-full px-4 py-2.5 pr-10 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all duration-200"
                                />
                              </div>

                              <%= for msg <- @form[:tarikh_dijangka_siap].errors do %>
                                <p class="mt-1.5 flex gap-2 items-center text-sm text-red-600">
                                  <.icon name="hero-exclamation-circle" class="size-5 shrink-0" /> {msg}
                                </p>
                              <% end %>
                            </div>

                            <div>
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Keutamaan
                              </label>
                              <select
                                name="perubahan[keutamaan]"
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                              >
                                <option
                                  value="Sangat Tinggi"
                                  selected={@form[:keutamaan].value == "Sangat Tinggi"}
                                >
                                  Sangat Tinggi
                                </option>

                                <option
                                  value="Tinggi"
                                  selected={@form[:keutamaan].value == "Tinggi"}
                                >
                                  Tinggi
                                </option>

                                <option
                                  value="Sederhana"
                                  selected={@form[:keutamaan].value == "Sederhana"}
                                >
                                  Sederhana
                                </option>

                                <option
                                  value="Rendah"
                                  selected={@form[:keutamaan].value == "Rendah"}
                                >
                                  Rendah
                                </option>
                              </select>
                            </div>

                            <div class="md:col-span-2">
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Justifikasi
                              </label>
                              <textarea
                                name="perubahan[justifikasi]"
                                rows="3"
                                placeholder="Masukkan justifikasi perubahan..."
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none"
                              ><%= if @form[:justifikasi] && @form[:justifikasi].value, do: @form[:justifikasi].value, else: "" %></textarea>
                            </div>

                            <div class="md:col-span-2">
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Kesan
                              </label>
                              <textarea
                                name="perubahan[kesan]"
                                rows="3"
                                placeholder="Masukkan kesan perubahan..."
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none"
                              ><%= if @form[:kesan] && @form[:kesan].value, do: @form[:kesan].value, else: "" %></textarea>
                            </div>

                            <div class="md:col-span-2">
                              <label class="block text-sm font-medium text-gray-800 mb-2">
                                Catatan
                              </label>
                              <textarea
                                name="perubahan[catatan]"
                                rows="3"
                                placeholder="Masukkan catatan..."
                                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none"
                              ><%= if @form[:catatan] && @form[:catatan].value, do: @form[:catatan].value, else: "" %></textarea>
                            </div>
                          </div>
                        </.form>
                      </div>
                      <%!-- Modal footer --%>
                      <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex justify-end gap-3">
                        <button
                          type="button"
                          phx-click="close_edit_modal"
                          class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium"
                        >
                          Batal
                        </button>
                        <button
                          type="submit"
                          form="edit-perubahan-form"
                          class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200 font-medium"
                        >
                          Simpan Perubahan
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            <% @current_tab == "UAT" -> %>
              <div class="space-y-6">
                <%!-- List view only; detail view removed - use expand on each row to see kes ujian --%>
                <div class="mb-6 flex items-center justify-between gap-3">
                  <div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">
                      Ujian Penerimaan Pengguna (UAT)
                    </h3>
                    <p class="text-gray-600 text-sm">
                      Urus dan pantau pelaksanaan ujian penerimaan pengguna bagi modul sistem.
                    </p>
                    <p class="mt-1 text-xs text-gray-500">
                      Projek: <span class="font-semibold text-gray-800">{@project.nama}</span>
                    </p>
                  </div>

                  <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2">
                    <button
                      phx-click="open_uat_create_modal"
                      class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 text-sm font-medium shadow-md hover:shadow-lg transition"
                    >
                      <.icon name="hero-plus-circle" class="w-5 h-5" />
                      <span>Daftar Ujian Baharu</span>
                    </button>
                  </div>
                </div>

                <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-100">
                  <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-800 flex items-center justify-between">
                    <div>
                      <h2 class="text-lg font-semibold text-white">
                        Senarai Ujian Penerimaan Pengguna
                      </h2>
                      <p class="text-xs text-blue-100">
                        {@uat_ujian_total} rekod ujian dijumpai.
                      </p>
                    </div>
                  </div>

                  <%= if @uat_ujian_total == 0 do %>
                    <div class="px-6 py-12 text-center">
                      <div class="flex flex-col items-center justify-center text-gray-400">
                        <.icon name="hero-inbox" class="w-12 h-12 mb-3" />
                        <p class="text-sm font-medium">Tiada ujian penerimaan pengguna.</p>
                        <p class="text-xs mt-1">
                          Klik &quot;Daftar Ujian Baharu&quot; untuk menambah rekod ujian bagi modul
                          projek.
                        </p>
                      </div>
                    </div>
                  <% else %>
                    <div class="overflow-x-auto">
                      <table class="w-full text-sm">
                        <thead class="bg-gray-50 border-b border-gray-200">
                          <tr>
                            <th class="px-2 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-10">
                              <span class="sr-only">Kembang</span>
                            </th>
                            <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-14">
                              Bil
                            </th>
                            <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-left">
                              Modul
                            </th>
                            <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-left">
                              Tajuk Ujian
                            </th>
                            <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-36">
                              Tarikh Ujian
                            </th>
                            <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-40">
                              Tarikh Dijangka Siap
                            </th>
                            <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-32">
                              Status
                            </th>
                            <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-40">
                              Penguji
                            </th>
                            <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-32">
                              Tindakan
                            </th>
                          </tr>
                        </thead>

                        <tbody class="bg-white divide-y divide-gray-200">
                          <%= for {ujian, idx} <- Enum.with_index(@uat_paginated_ujian, 0) do %>
                            <tr class="hover:bg-gray-50 transition-colors duration-150">
                              <td class="px-2 py-2 text-center align-middle">
                                <button
                                  type="button"
                                  phx-click="uat_toggle_expand"
                                  phx-value-ujian_id={ujian.id}
                                  class={[
                                    "inline-flex items-center justify-center w-8 h-8 rounded-lg transition-transform duration-200",
                                    if(@uat_expanded_ujian_id == ujian.id,
                                      do: "bg-blue-100 text-blue-700 rotate-90",
                                      else: "text-gray-500 hover:bg-gray-100 hover:text-gray-700"
                                    )
                                  ]}
                                  title={
                                    if(@uat_expanded_ujian_id == ujian.id,
                                      do: "Tutup senarai kes ujian",
                                      else: "Kembang senarai kes ujian"
                                    )
                                  }
                                >
                                  <.icon name="hero-chevron-right" class="w-5 h-5" />
                                </button>
                              </td>
                              <td class="px-3 py-2 text-center text-xs font-medium text-gray-700">
                                {@uat_per_page * (@uat_page - 1) + idx + 1}
                              </td>
                              <td class="px-3 py-2 text-sm font-semibold text-gray-900">
                                {ujian.modul}
                              </td>
                              <td class="px-3 py-2 text-sm text-gray-800">
                                {ujian.tajuk}
                              </td>
                              <td class="px-3 py-2 text-xs text-center text-gray-700 whitespace-nowrap">
                                <%= if ujian.tarikh_ujian do %>
                                  {Calendar.strftime(ujian.tarikh_ujian, "%d/%m/%Y")}
                                <% else %>
                                  <span class="text-gray-400 italic">-</span>
                                <% end %>
                              </td>
                              <td class="px-3 py-2 text-xs text-center text-gray-700 whitespace-nowrap">
                                <%= if ujian.tarikh_dijangka_siap do %>
                                  {Calendar.strftime(ujian.tarikh_dijangka_siap, "%d/%m/%Y")}
                                <% else %>
                                  <span class="text-gray-400 italic">-</span>
                                <% end %>
                              </td>
                              <td class="px-3 py-2 text-xs text-center">
                                <span class={[
                                  "inline-flex items-center px-2 py-0.5 rounded-full border text-[11px] font-medium",
                                  case ujian.status do
                                    "Menunggu" -> "bg-yellow-50 text-yellow-800 border-yellow-200"
                                    "Dalam Progres" -> "bg-blue-50 text-blue-800 border-blue-200"
                                    "Selesai" -> "bg-green-50 text-green-800 border-green-200"
                                    _ -> "bg-gray-50 text-gray-700 border-gray-200"
                                  end
                                ]}>
                                  {ujian.status || "Menunggu"}
                                </span>
                              </td>
                              <td class="px-3 py-2 text-xs text-center text-gray-700">
                                <%= if ujian.penguji do %>
                                  {ujian.penguji}
                                <% else %>
                                  <span class="text-gray-400 italic">Belum ditetapkan</span>
                                <% end %>
                              </td>
                              <td class="px-3 py-2 text-xs text-center">
                                <div class="inline-flex items-center gap-1.5">
                                  <button
                                    type="button"
                                    phx-click="uat_toggle_expand"
                                    phx-value-ujian_id={ujian.id}
                                    class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white hover:bg-gray-50 border border-gray-200 text-gray-700 shadow-sm hover:shadow transition"
                                    title="Lihat butiran dan kes ujian"
                                  >
                                    <.icon name="hero-eye" class="w-4 h-4" />
                                  </button>

                                  <button
                                    phx-click="open_uat_edit_modal"
                                    phx-value-ujian_id={ujian.id}
                                    class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 hover:bg-blue-100 text-blue-700 border border-blue-200 transition"
                                    title="Kemaskini ujian"
                                  >
                                    <.icon name="hero-pencil-square" class="w-4 h-4" />
                                  </button>
                                </div>
                              </td>
                            </tr>
                            <%= if @uat_expanded_ujian_id == ujian.id && @uat_expanded_ujian do %>
                              <tr class="bg-gray-50/80">
                                <td colspan="9" class="px-0 py-0 align-top">
                                  <div class="px-4 pb-4 pt-1">
                                    <div class="bg-white rounded-xl shadow border border-gray-200 overflow-hidden">
                                      <div class="px-4 py-3 bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-800 flex items-center justify-between">
                                        <div>
                                          <h3 class="text-base font-semibold text-white">
                                            Senarai Kes Ujian
                                          </h3>
                                          <p class="text-xs text-blue-100">
                                            Rekod terperinci senario, langkah dan keputusan ujian.
                                          </p>
                                        </div>
                                        <div class="inline-flex items-center gap-2">
                                          <button
                                            type="button"
                                            phx-click="open_uat_add_column_modal"
                                            class="inline-flex items-center gap-2 px-3 py-1.5 bg-amber-500/90 hover:bg-amber-500 text-white border border-amber-400 rounded-lg text-xs font-medium shadow-sm transition"
                                          >
                                            <.icon name="hero-plus" class="w-4 h-4" />
                                            <span>Tambah Lajur</span>
                                          </button>
                                          <button
                                            type="button"
                                            phx-click="open_add_kes_modal"
                                            phx-value-ujian_id={@uat_expanded_ujian.id}
                                            class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 hover:bg-white/20 text-white border border-white/30 rounded-lg text-xs font-medium shadow-sm transition"
                                          >
                                            <.icon name="hero-plus" class="w-4 h-4" />
                                            <span>Tambah Kes Ujian</span>
                                          </button>
                                        </div>
                                      </div>
                                      <%= if @uat_expanded_ujian.senarai_kes_ujian && @uat_expanded_ujian.senarai_kes_ujian != [] do %>
                                        <div class="overflow-x-auto">
                                          <table class="w-full text-sm">
                                            <thead class="bg-gray-50 border-b border-gray-200">
                                              <tr>
                                                <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-left w-20">
                                                  Kod
                                                </th>
                                                <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-left">
                                                  Senario
                                                </th>
                                                <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-left w-44">
                                                  Keputusan Dijangka
                                                </th>
                                                <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-left w-44">
                                                  Keputusan Sebenar
                                                </th>
                                                <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-28">
                                                  Hasil
                                                </th>
                                                <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-32">
                                                  Penguji / Tarikh
                                                </th>
                                                <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-40">
                                                  Pengesahan
                                                </th>
                                                <th
                                                  :for={
                                                    col <- @uat_expanded_ujian.extra_columns || []
                                                  }
                                                  class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-left min-w-[100px]"
                                                >
                                                  <div class="flex items-center justify-between gap-1">
                                                    <span>{col["label"]}</span>
                                                    <button
                                                      type="button"
                                                      phx-click="remove_uat_column"
                                                      phx-value-column_id={col["id"]}
                                                      phx-value-ujian_id={@uat_expanded_ujian.id}
                                                      class="p-0.5 rounded text-gray-400 hover:text-red-600 hover:bg-red-50"
                                                      title="Buang lajur"
                                                    >
                                                      <.icon
                                                        name="hero-x-mark"
                                                        class="w-3.5 h-3.5"
                                                      />
                                                    </button>
                                                  </div>
                                                </th>
                                                <th class="px-3 py-2 text-xs font-semibold text-gray-700 uppercase tracking-wider text-center w-32">
                                                  Tindakan
                                                </th>
                                              </tr>
                                            </thead>
                                            <tbody class="bg-white divide-y divide-gray-200">
                                              <tr
                                                :for={
                                                  kes <- @uat_expanded_ujian.senarai_kes_ujian
                                                }
                                                class="hover:bg-gray-50 align-top"
                                              >
                                                <td class="px-3 py-2 text-xs font-semibold text-gray-800 whitespace-nowrap">
                                                  {Map.get(kes, :kod, kes.id)}
                                                </td>
                                                <td class="px-3 py-2 text-xs text-gray-800">
                                                  <p class="font-medium mb-0.5">
                                                    {if kes.senario, do: kes.senario, else: "-"}
                                                  </p>
                                                  <%= if kes.langkah do %>
                                                    <p class="text-[11px] text-gray-600 whitespace-pre-line">
                                                      {kes.langkah}
                                                    </p>
                                                  <% end %>
                                                </td>
                                                <td class="px-3 py-2 text-xs text-gray-700">
                                                  <%= if kes.keputusan_dijangka do %>
                                                    <p class="whitespace-pre-line">
                                                      {kes.keputusan_dijangka}
                                                    </p>
                                                  <% else %>
                                                    <span class="text-gray-400 italic">-</span>
                                                  <% end %>
                                                </td>
                                                <td class="px-3 py-2 text-xs text-gray-700">
                                                  <%= if kes.keputusan_sebenar do %>
                                                    <p class="whitespace-pre-line">
                                                      {kes.keputusan_sebenar}
                                                    </p>
                                                  <% else %>
                                                    <span class="text-gray-400 italic">
                                                      Belum diuji / tiada rekod
                                                    </span>
                                                  <% end %>
                                                </td>
                                                <td class="px-3 py-2 text-xs text-center">
                                                  <span class={[
                                                    "inline-flex items-center px-2 py-0.5 rounded-full border text-[11px] font-medium",
                                                    case kes.hasil do
                                                      "Lulus" ->
                                                        "bg-green-50 text-green-800 border-green-200"

                                                      "Gagal" ->
                                                        "bg-red-50 text-red-800 border-red-200"

                                                      _ ->
                                                        "bg-gray-50 text-gray-700 border-gray-200"
                                                    end
                                                  ]}>
                                                    {kes.hasil || "Belum Ditentukan"}
                                                  </span>
                                                </td>
                                                <td class="px-3 py-2 text-xs text-center">
                                                  <p class="font-medium">
                                                    {if Map.get(kes, :penguji),
                                                      do: kes.penguji,
                                                      else: "-"}
                                                  </p>
                                                  <p class="text-[11px] text-gray-500">
                                                    {if kes.tarikh_ujian,
                                                      do:
                                                        Calendar.strftime(
                                                          kes.tarikh_ujian,
                                                          "%d/%m/%Y"
                                                        ),
                                                      else: "Tiada tarikh"}
                                                  </p>
                                                </td>
                                                <td class="px-3 py-2 text-xs text-center">
                                                  <p class="font-medium">
                                                    {if Map.get(kes, :disahkan_oleh),
                                                      do: kes.disahkan_oleh,
                                                      else: "Belum disahkan"}
                                                  </p>
                                                  <p class="text-[11px] text-gray-500">
                                                    {if kes.tarikh_pengesahan,
                                                      do:
                                                        Calendar.strftime(
                                                          kes.tarikh_pengesahan,
                                                          "%d/%m/%Y"
                                                        ),
                                                      else: "Tiada tarikh"}
                                                  </p>
                                                </td>
                                                <td
                                                  :for={
                                                    col <- @uat_expanded_ujian.extra_columns || []
                                                  }
                                                  class="px-3 py-2 text-xs text-gray-700"
                                                >
                                                  {Map.get(kes.extra_values || %{}, col["id"], "")}
                                                </td>
                                                <td class="px-3 py-2 text-xs text-center">
                                                  <div class="inline-flex items-center gap-1">
                                                    <button
                                                      type="button"
                                                      phx-click="edit_kes_ujian"
                                                      phx-value-kes_id={kes.id}
                                                      class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-blue-50 hover:bg-blue-100 text-blue-700 border border-blue-200 transition"
                                                      title="Kemaskini kes ujian"
                                                    >
                                                      <.icon
                                                        name="hero-pencil-square"
                                                        class="w-4 h-4"
                                                      />
                                                    </button>
                                                    <button
                                                      type="button"
                                                      phx-click="delete_kes_ujian"
                                                      phx-value-kes_id={kes.id}
                                                      data-confirm="Padam kes ujian ini?"
                                                      class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-red-50 hover:bg-red-100 text-red-700 border border-red-200 transition"
                                                      title="Padam kes ujian"
                                                    >
                                                      <.icon name="hero-trash" class="w-4 h-4" />
                                                    </button>
                                                  </div>
                                                </td>
                                              </tr>
                                            </tbody>
                                          </table>
                                        </div>
                                      <% else %>
                                        <div class="px-4 py-8 text-center text-gray-400">
                                          <p class="text-sm font-medium">
                                            Tiada kes ujian direkodkan.
                                          </p>
                                          <p class="text-xs mt-1">
                                            Klik &quot;Tambah Kes Ujian&quot; untuk mendaftarkan kes ujian pertama bagi modul ini.
                                          </p>
                                        </div>
                                      <% end %>
                                    </div>
                                  </div>
                                </td>
                              </tr>
                            <% end %>
                          <% end %>
                        </tbody>
                      </table>
                    </div>

                    <%!-- Pagination --%>
                    <div class="px-6 py-4 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-3 bg-gray-50">
                      <p class="text-xs text-gray-500">
                        Menunjukkan
                        <span class="font-semibold">
                          <%= if @uat_ujian_total > 0 do %>
                            {@uat_per_page * (@uat_page - 1) + 1}
                          <% else %>
                            0
                          <% end %>
                        </span>
                        hingga
                        <span class="font-semibold">
                          {min(@uat_per_page * @uat_page, @uat_ujian_total)}
                        </span>
                        daripada
                        <span class="font-semibold">
                          {@uat_ujian_total}
                        </span>
                        rekod
                      </p>

                      <div class="flex items-center gap-2">
                        <button
                          phx-click="uat_prev_page"
                          class={[
                            "px-3 py-1.5 rounded-lg border text-xs font-medium flex items-center gap-1.5 transition",
                            if(@uat_page == 1,
                              do: "border-gray-200 text-gray-300 bg-white cursor-not-allowed",
                              else:
                                "border-gray-300 text-gray-700 bg-white hover:bg-gray-50 hover:border-gray-400"
                            )
                          ]}
                          disabled={@uat_page == 1}
                        >
                          <.icon name="hero-chevron-left" class="w-3.5 h-3.5" />
                          <span>Sebelumnya</span>
                        </button>

                        <div class="flex items-center gap-1 text-xs text-gray-600">
                          <span>Halaman</span>
                          <form phx-submit="uat_go_to_page" class="flex items-center gap-1">
                            <input
                              type="number"
                              name="page"
                              min="1"
                              value={@uat_page}
                              max={@uat_total_pages}
                              class="w-14 px-2 py-1 border border-gray-300 rounded-md text-xs focus:ring-1 focus:ring-blue-500 focus:border-blue-500"
                            />
                            <span class="text-gray-500">/ {@uat_total_pages}</span>
                          </form>
                        </div>

                        <button
                          phx-click="uat_next_page"
                          class={[
                            "px-3 py-1.5 rounded-lg border text-xs font-medium flex items-center gap-1.5 transition",
                            if(@uat_page >= @uat_total_pages,
                              do: "border-gray-200 text-gray-300 bg-white cursor-not-allowed",
                              else:
                                "border-gray-300 text-gray-700 bg-white hover:bg-gray-50 hover:border-gray-400"
                            )
                          ]}
                          disabled={@uat_page >= @uat_total_pages}
                        >
                          <span>Seterusnya</span>
                          <.icon name="hero-chevron-right" class="w-3.5 h-3.5" />
                        </button>
                      </div>
                    </div>
                  <% end %>
                </div>

                <%!-- Create / Edit ujian modal --%>
                <%= if @uat_show_create_modal || @uat_show_edit_modal do %>
                  <div class="fixed inset-0 z-[60] flex items-center justify-center bg-gray-900/60 backdrop-blur-sm">
                    <div class="bg-white rounded-2xl shadow-2xl max-w-xl w-full mx-4 overflow-hidden border border-gray-200">
                      <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 flex items-center justify-between">
                        <div>
                          <h3 class="text-base font-semibold text-white">
                            <%= if @uat_show_create_modal do %>
                              Daftar Ujian Penerimaan Pengguna
                            <% else %>
                              Kemaskini Ujian Penerimaan Pengguna
                            <% end %>
                          </h3>
                          <p class="text-[11px] text-blue-100 mt-0.5">
                            Lengkapkan maklumat ujian sebelum melaksanakan kes ujian terperinci.
                          </p>
                        </div>

                        <button
                          phx-click={
                            if(@uat_show_create_modal,
                              do: "close_uat_create_modal",
                              else: "close_uat_edit_modal"
                            )
                          }
                          class="text-blue-100 hover:text-white rounded-full p-1.5 hover:bg-white/10 transition"
                        >
                          <.icon name="hero-x-mark" class="w-5 h-5" />
                        </button>
                      </div>

                      <div class="px-6 py-5 space-y-4 max-h-[75vh] overflow-y-auto">
                        <.form
                          for={@uat_form}
                          id="uat-ujian-form"
                          phx-submit={
                            if(@uat_show_create_modal,
                              do: "create_uat_ujian",
                              else: "update_uat_ujian"
                            )
                          }
                          phx-change="validate_uat_ujian"
                        >
                          <div class="grid grid-cols-1 gap-4">
                            <div>
                              <.input
                                field={@uat_form[:tajuk]}
                                type="text"
                                label="Tajuk Ujian"
                                placeholder="Contoh: Ujian penerimaan modul pendaftaran pengguna"
                              />
                              <p class="mt-1 text-[11px] text-gray-500">
                                Tajuk hendaklah jelas dan mewakili objektif ujian.
                              </p>
                            </div>

                            <div>
                              <label class="block text-sm font-medium text-gray-700 mb-1">
                                Modul
                              </label>
                              <select
                                name="ujian[modul]"
                                class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm"
                                value={@uat_form[:modul].value}
                              >
                                <option value="">-- Pilih Modul --</option>
                                <option
                                  :for={mod <- @senarai_nama_modul_ordered}
                                  value={mod}
                                  selected={@uat_form[:modul].value == mod}
                                >
                                  {mod}
                                </option>
                              </select>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                              <.input
                                field={@uat_form[:tarikh_ujian]}
                                type="date"
                                label="Tarikh Ujian"
                              />
                              <.input
                                field={@uat_form[:tarikh_dijangka_siap]}
                                type="date"
                                label="Tarikh Dijangka Siap"
                              />
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                              <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">
                                  Status
                                </label>
                                <select
                                  name="ujian[status]"
                                  class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm"
                                  value={@uat_form[:status].value || "Menunggu"}
                                >
                                  <option value="Menunggu">Menunggu</option>
                                  <option value="Dalam Progres">Dalam Progres</option>
                                  <option value="Selesai">Selesai</option>
                                </select>
                              </div>

                              <.input
                                field={@uat_form[:penguji]}
                                type="text"
                                label="Nama Penguji"
                                placeholder="Contoh: Ahmad bin Ali"
                              />
                            </div>

                            <.input
                              field={@uat_form[:hasil]}
                              type="text"
                              label="Ringkasan Hasil"
                              placeholder="Contoh: Majoriti kes ujian lulus dengan beberapa isu kecil..."
                            />

                            <.input
                              field={@uat_form[:catatan]}
                              type="textarea"
                              label="Catatan Tambahan"
                              placeholder="Catatan tambahan berkaitan skop, risiko atau penemuan penting semasa ujian."
                              rows="3"
                            />
                          </div>

                          <div class="mt-6 flex items-center justify-between gap-3">
                            <button
                              type="button"
                              phx-click={
                                if(@uat_show_create_modal,
                                  do: "close_uat_create_modal",
                                  else: "close_uat_edit_modal"
                                )
                              }
                              class="inline-flex items-center justify-center gap-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg bg-white hover:bg-gray-50 text-sm font-medium shadow-sm transition"
                            >
                              <.icon name="hero-x-mark" class="w-4 h-4" />
                              <span>Batal</span>
                            </button>

                            <button
                              type="submit"
                              class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 text-sm font-medium shadow-md hover:shadow-lg transition"
                            >
                              <.icon name="hero-check-circle" class="w-5 h-5" />
                              <span>
                                <%= if @uat_show_create_modal do %>
                                  Simpan &amp; Daftar
                                <% else %>
                                  Simpan Perubahan
                                <% end %>
                              </span>
                            </button>
                          </div>
                        </.form>
                      </div>
                    </div>
                  </div>
                <% end %>

                <%!-- Edit kes ujian modal --%>
                <%= if @uat_show_edit_kes_modal do %>
                  <div class="fixed inset-0 z-[60] flex items-center justify-center bg-gray-900/60 backdrop-blur-sm">
                    <div class="bg-white rounded-2xl shadow-2xl max-w-3xl w-full mx-4 overflow-hidden border border-gray-200">
                      <div class="px-6 py-4 bg-gradient-to-r from-amber-500 to-amber-600 flex items-center justify-between">
                        <div>
                          <h3 class="text-base font-semibold text-white">
                            Kemaskini Kes Ujian
                          </h3>
                          <p class="text-[11px] text-amber-100 mt-0.5">
                            Perincikan senario, langkah, keputusan dan maklumat pengesahan bagi kes ujian ini.
                          </p>
                        </div>

                        <button
                          phx-click="close_edit_kes_modal"
                          class="text-amber-100 hover:text-white rounded-full p-1.5 hover:bg-white/10 transition"
                        >
                          <.icon name="hero-x-mark" class="w-5 h-5" />
                        </button>
                      </div>

                      <div class="px-6 py-5 space-y-4 max-h-[80vh] overflow-y-auto">
                        <.form
                          for={@uat_kes_form}
                          id="uat-edit-kes-form"
                          phx-submit="update_kes"
                          phx-change="validate_kes"
                        >
                          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                            <.input
                              field={@uat_kes_form[:senario]}
                              type="textarea"
                              label="Senario Ujian"
                              rows="3"
                              placeholder="Terangkan latar belakang dan tujuan kes ujian ini."
                            />
                            <.input
                              field={@uat_kes_form[:langkah]}
                              type="textarea"
                              label="Langkah Ujian"
                              rows="3"
                              placeholder="Senaraikan langkah-langkah terperinci yang perlu dilaksanakan."
                            />
                            <.input
                              field={@uat_kes_form[:keputusan_dijangka]}
                              type="textarea"
                              label="Keputusan Dijangka"
                              rows="3"
                              placeholder="Apakah keputusan yang dijangka apabila langkah-langkah dipatuhi?"
                            />
                            <.input
                              field={@uat_kes_form[:keputusan_sebenar]}
                              type="textarea"
                              label="Keputusan Sebenar"
                              rows="3"
                              placeholder="Rekodkan keputusan sebenar semasa ujian dilaksanakan."
                            />
                            <.input
                              field={@uat_kes_form[:hasil]}
                              type="textarea"
                              label="Ringkasan Hasil"
                              rows="3"
                              placeholder="Contoh: Lulus tanpa isu / Gagal - ralat paparan mesej..."
                            />
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                              <.input
                                field={@uat_kes_form[:penguji]}
                                type="text"
                                label="Nama Penguji"
                                placeholder="Contoh: Noraini binti Salleh"
                              />
                              <.input
                                field={@uat_kes_form[:tarikh_ujian]}
                                type="date"
                                label="Tarikh Ujian"
                              />
                              <.input
                                field={@uat_kes_form[:disahkan_oleh]}
                                type="text"
                                label="Disahkan Oleh"
                                placeholder="Contoh: Ketua Penolong Pengarah"
                              />
                              <.input
                                field={@uat_kes_form[:tarikh_pengesahan]}
                                type="date"
                                label="Tarikh Pengesahan"
                              />
                            </div>
                          </div>

                          <div class="mt-6 flex items-center justify-between gap-3">
                            <button
                              type="button"
                              phx-click="close_edit_kes_modal"
                              class="inline-flex items-center justify-center gap-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg bg-white hover:bg-gray-50 text-sm font-medium shadow-sm transition"
                            >
                              <.icon name="hero-x-mark" class="w-4 h-4" />
                              <span>Batal</span>
                            </button>

                            <button
                              type="submit"
                              class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-gradient-to-r from-amber-500 to-amber-600 text-white rounded-lg hover:from-amber-600 hover:to-amber-700 text-sm font-medium shadow-md hover:shadow-lg transition"
                            >
                              <.icon name="hero-check-circle" class="w-5 h-5" />
                              <span>Simpan Perubahan</span>
                            </button>
                          </div>
                        </.form>
                      </div>
                    </div>
                  </div>
                <% end %>

                <%!-- Add kes ujian modal --%>
                <%= if @uat_show_add_kes_modal do %>
                  <div class="fixed inset-0 z-[60] flex items-center justify-center bg-gray-900/60 backdrop-blur-sm">
                    <div class="bg-white rounded-2xl shadow-2xl max-w-3xl w-full mx-4 overflow-hidden border border-gray-200">
                      <div class="px-6 py-4 bg-gradient-to-r from-emerald-500 to-emerald-600 flex items-center justify-between">
                        <div>
                          <h3 class="text-base font-semibold text-white">
                            Tambah Kes Ujian Baharu
                          </h3>
                          <p class="text-[11px] text-emerald-100 mt-0.5">
                            Rekodkan kes ujian baharu untuk modul ini bagi memastikan kualiti sistem terjamin.
                          </p>
                        </div>

                        <button
                          phx-click="close_add_kes_modal"
                          class="text-emerald-100 hover:text-white rounded-full p-1.5 hover:bg-white/10 transition"
                        >
                          <.icon name="hero-x-mark" class="w-5 h-5" />
                        </button>
                      </div>

                      <div class="px-6 py-5 space-y-4 max-h-[80vh] overflow-y-auto">
                        <.form
                          for={@uat_kes_form}
                          id="uat-add-kes-form"
                          phx-submit="create_kes"
                          phx-change="validate_add_kes"
                        >
                          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                            <.input
                              field={@uat_kes_form[:senario]}
                              type="textarea"
                              label="Senario Ujian"
                              rows="3"
                              placeholder="Terangkan keadaan dan objektif kes ujian."
                            />
                            <.input
                              field={@uat_kes_form[:langkah]}
                              type="textarea"
                              label="Langkah Ujian"
                              rows="3"
                              placeholder="Senaraikan langkah-langkah terperinci yang perlu diikuti."
                            />
                            <.input
                              field={@uat_kes_form[:keputusan_dijangka]}
                              type="textarea"
                              label="Keputusan Dijangka"
                              rows="3"
                              placeholder="Nyatakan keputusan yang sepatutnya diperolehi."
                            />
                            <.input
                              field={@uat_kes_form[:keputusan_sebenar]}
                              type="textarea"
                              label="Keputusan Sebenar"
                              rows="3"
                              placeholder="Biarkan kosong jika ujian belum dijalankan."
                            />
                            <.input
                              field={@uat_kes_form[:hasil]}
                              type="textarea"
                              label="Ringkasan Hasil"
                              rows="3"
                              placeholder="Contoh: Lulus / Gagal dengan isu tertentu..."
                            />
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                              <.input
                                field={@uat_kes_form[:penguji]}
                                type="text"
                                label="Nama Penguji"
                                placeholder="Contoh: Zulkifli bin Mat"
                              />
                              <.input
                                field={@uat_kes_form[:tarikh_ujian]}
                                type="date"
                                label="Tarikh Ujian"
                              />
                              <.input
                                field={@uat_kes_form[:disahkan_oleh]}
                                type="text"
                                label="Disahkan Oleh"
                                placeholder="Contoh: Ketua Penolong Pengarah"
                              />
                              <.input
                                field={@uat_kes_form[:tarikh_pengesahan]}
                                type="date"
                                label="Tarikh Pengesahan"
                              />
                            </div>
                          </div>

                          <div class="mt-6 flex items-center justify-between gap-3">
                            <button
                              type="button"
                              phx-click="close_add_kes_modal"
                              class="inline-flex items-center justify-center gap-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg bg-white hover:bg-gray-50 text-sm font-medium shadow-sm transition"
                            >
                              <.icon name="hero-x-mark" class="w-4 h-4" />
                              <span>Batal</span>
                            </button>

                            <button
                              type="submit"
                              class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-gradient-to-r from-emerald-500 to-emerald-600 text-white rounded-lg hover:from-emerald-600 hover:to-emerald-700 text-sm font-medium shadow-md hover:shadow-lg transition"
                            >
                              <.icon name="hero-plus-circle" class="w-5 h-5" />
                              <span>Simpan &amp; Tambah</span>
                            </button>
                          </div>
                        </.form>
                      </div>
                    </div>
                  </div>
                <% end %>

                <%!-- Modal Tambah Lajur (dynamic column) --%>
                <%= if @uat_show_add_column_modal do %>
                  <div class="fixed inset-0 z-[60] flex items-center justify-center bg-gray-900/60 backdrop-blur-sm">
                    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4 overflow-hidden border border-gray-200">
                      <div class="px-6 py-4 bg-gradient-to-r from-amber-500 to-amber-600 flex items-center justify-between">
                        <h3 class="text-base font-semibold text-white">Tambah Lajur</h3>
                        <button
                          type="button"
                          phx-click="close_uat_add_column_modal"
                          class="p-1.5 rounded-lg text-white/90 hover:bg-white/20 transition"
                        >
                          <.icon name="hero-x-mark" class="w-5 h-5" />
                        </button>
                      </div>
                      <.form
                        for={@uat_kes_column_form}
                        id="uat-add-column-form"
                        phx-change="validate_uat_column"
                        phx-submit="add_uat_column"
                        class="p-6 space-y-4"
                      >
                        <.input
                          field={@uat_kes_column_form[:label]}
                          type="text"
                          label="Nama lajur"
                          placeholder="Contoh: Nota, Rujukan"
                          class="w-full"
                        />
                        <div class="flex items-center justify-end gap-3 pt-2">
                          <button
                            type="button"
                            phx-click="close_uat_add_column_modal"
                            class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg bg-white hover:bg-gray-50 text-sm font-medium transition"
                          >
                            Batal
                          </button>
                          <button
                            type="submit"
                            class="inline-flex items-center gap-2 px-5 py-2.5 bg-amber-500 hover:bg-amber-600 text-white rounded-lg text-sm font-medium shadow transition"
                          >
                            <.icon name="hero-plus" class="w-4 h-4" /> Tambah Lajur
                          </button>
                        </div>
                      </.form>
                    </div>
                  </div>
                <% end %>
              </div>
            <% @current_tab == "Ujian Keselamatan" -> %>
              <div class="space-y-6">
                <%= if false && assigns[:kes_selected_ujian] do %>
                  <%!-- Detail Ujian --%>
                  <div class="mb-6">
                    <div class="flex items-center gap-4 mb-4">
                      <.link
                        patch={~p"/projek/#{@project.id}?tab=ujian-keselamatan"}
                        class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors duration-200"
                      >
                        <.icon name="hero-arrow-left" class="w-4 h-4" />
                        <span>Kembali ke Senarai Ujian</span>
                      </.link>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-900 mb-2">{@kes_selected_ujian.tajuk}</h2>
                    <p class="text-gray-600">Butiran lengkap ujian keselamatan</p>
                  </div>
                  <%!-- Maklumat Ujian Table --%>
                  <div class="bg-white rounded-xl shadow-lg overflow-hidden mb-6">
                    <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-800 flex items-center justify-between">
                      <h3 class="text-xl font-semibold text-white">Maklumat Ujian</h3>
                      <button
                        phx-click="kes_add_new_kes"
                        class="flex items-center gap-2 px-4 py-2 bg-white/20 hover:bg-white/30 text-white rounded-lg transition-all duration-200 font-medium text-sm"
                      >
                        <.icon name="hero-plus-circle" class="w-5 h-5" />
                        <span>Tambah Kes Ujian</span>
                      </button>
                    </div>
                    <div class="overflow-x-auto">
                      <table class="w-full text-sm table-auto">
                        <thead class="bg-gray-50 border-b border-gray-200">
                          <tr>
                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-32">ID Kes Ujian</th>
                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider min-w-[200px]">Senario Ujian</th>
                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider min-w-[150px]">Langkah Ujian</th>
                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-36">Keputusan Dijangka</th>
                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-36">Keputusan Sebenar</th>
                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-32">Hasil</th>
                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider min-w-[120px]">Di Uji Oleh</th>
                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-32">Tarikh Ujian</th>
                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-28">Disahkan Oleh</th>
                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider w-36">Tarikh Pengesahan</th>
                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-28">Tindakan</th>
                          </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                          <%= if length(Map.get(@kes_selected_ujian, :senarai_kes_ujian, [])) == 0 do %>
                            <tr>
                              <td colspan="11" class="px-6 py-12 text-center">
                                <div class="flex flex-col items-center justify-center text-gray-400">
                                  <.icon name="hero-inbox" class="w-12 h-12 mb-3" />
                                  <p class="text-sm font-medium">Tiada kes ujian</p>
                                </div>
                              </td>
                            </tr>
                          <% else %>
                            <tr
                              :for={kes <- Map.get(@kes_selected_ujian, :senarai_kes_ujian, [])}
                              class="hover:bg-gray-50 transition-colors duration-150"
                            >
                              <td class="px-3 py-3"><span class="text-gray-900 font-mono text-xs">{kes[:kod] || kes.id}</span></td>
                              <td class="px-3 py-3"><span class="text-gray-900 font-semibold">{kes.senario}</span></td>
                              <td class="px-3 py-3"><span class="text-gray-900 text-xs whitespace-pre-wrap font-mono tabular-nums leading-relaxed">{kes.langkah}</span></td>
                              <td class="px-3 py-3"><span class="text-gray-900 text-xs whitespace-pre-wrap">{kes.keputusan_dijangka}</span></td>
                              <td class="px-3 py-3"><span class="text-gray-500 text-xs whitespace-pre-wrap">{if kes.keputusan_sebenar, do: kes.keputusan_sebenar, else: ""}</span></td>
                              <td class="px-3 py-3 text-center">
                                <%= if kes.hasil do %>
                                  <span class={[
                                    "inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border",
                                    case kes.hasil do
                                      "Lulus" -> "bg-green-100 text-green-800 border-green-200"
                                      "Gagal" -> "bg-red-100 text-red-800 border-red-200"
                                      _ -> "bg-gray-100 text-gray-800 border-gray-200"
                                    end
                                  ]}>
                                    <.icon name={if kes.hasil == "Lulus", do: "hero-check-circle", else: if(kes.hasil == "Gagal", do: "hero-x-circle", else: "hero-information-circle")} class="w-3 h-3 mr-1" />
                                    {kes.hasil}
                                  </span>
                                <% end %>
                              </td>
                              <td class="px-3 py-3"><span class="text-gray-900 text-xs">{Map.get(kes, :penguji, "")}</span></td>
                              <td class="px-3 py-3">
                                <%= if Map.get(kes, :tarikh_ujian) do %>
                                  <div class="flex items-center gap-1.5">
                                    <.icon name="hero-calendar-days" class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" />
                                    <span class="text-gray-900 text-xs">{Calendar.strftime(kes.tarikh_ujian, "%d/%m/%Y")}</span>
                                  </div>
                                <% end %>
                              </td>
                              <td class="px-3 py-3 text-center">
                                <%= if Map.get(kes, :disahkan) do %>
                                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium border bg-green-100 text-green-800 border-green-200">
                                    <.icon name="hero-check-circle" class="w-3 h-3 mr-1" /> Ya
                                  </span>
                                <% end %>
                              </td>
                              <td class="px-3 py-3">
                                <%= if Map.get(kes, :tarikh_pengesahan) do %>
                                  <div class="flex items-center gap-1.5">
                                    <.icon name="hero-calendar-days" class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" />
                                    <span class="text-gray-900 text-xs">{Calendar.strftime(kes.tarikh_pengesahan, "%d/%m/%Y")}</span>
                                  </div>
                                <% end %>
                              </td>
                              <td class="px-3 py-3 text-center">
                                <div class="flex items-center justify-center gap-1.5">
                                  <button
                                    phx-click="kes_edit_kes_ujian"
                                    phx-value-kes_id={kes.id}
                                    class="p-1.5 text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-md transition-colors duration-200"
                                    title="Edit"
                                  >
                                    <.icon name="hero-pencil" class="w-4 h-4" />
                                  </button>
                                  <button
                                    phx-click="kes_delete_kes_ujian"
                                    phx-value-kes_id={kes.id}
                                    class="p-1.5 text-red-600 hover:text-red-800 hover:bg-red-50 rounded-md transition-colors duration-200"
                                    title="Padam"
                                  >
                                    <.icon name="hero-trash" class="w-4 h-4" />
                                  </button>
                                </div>
                              </td>
                            </tr>
                          <% end %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                <% else %>
                  <%!-- Senarai Ujian Keselamatan --%>
                  <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div>
                      <h2 class="text-4xl font-bold text-gray-900 mb-2">Ujian Keselamatan</h2>
                      <p class="text-gray-600">Urus dan pantau ujian keselamatan untuk modul sistem</p>
                    </div>
                    <div class="flex-shrink-0">
                      <button
                        phx-click="open_kes_create_modal"
                        class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 text-sm font-medium shadow-md hover:shadow-lg transition"
                      >
                        <.icon name="hero-plus-circle" class="w-5 h-5" />
                        <span>Daftar Ujian</span>
                      </button>
                    </div>
                  </div>
                  <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                    <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-800 flex items-center justify-between">
                      <h3 class="text-xl font-semibold text-white">Senarai Ujian Keselamatan</h3>
                    </div>
                    <% ujian_keselamatan_display = Enum.filter(@ujian_keselamatan, fn u -> Map.get(u, :tarikh_permohonan) != nil or Map.get(u, :tarikh_kelulusan) != nil or (v = Map.get(u, :upload_file)) != nil and v != "" or (s = Map.get(u, :status_kelulusan)) != nil and String.trim(s || "") != "" end) %>
                    <%= if length(ujian_keselamatan_display) == 0 do %>
                      <div class="px-6 py-12 text-center">
                        <div class="flex flex-col items-center justify-center text-gray-400">
                          <.icon name="hero-inbox" class="w-12 h-12 mb-3" />
                          <p class="text-sm font-medium">Tiada ujian keselamatan</p>
                          <p class="text-xs mt-1">Klik butang "Daftar Ujian" untuk menambah ujian baharu</p>
                        </div>
                      </div>
                    <% else %>
                      <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                          <thead class="bg-gray-50 border-b border-gray-200">
                            <tr>
                              <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Tarikh Permohonan</th>
                              <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Tarikh Kelulusan</th>
                              <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Upload File</th>
                              <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Status Kelulusan</th>
                              <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">Tindakan</th>
                            </tr>
                          </thead>
                          <tbody class="bg-white divide-y divide-gray-200">
                            <tr
                              :for={ujian <- ujian_keselamatan_display}
                              class="hover:bg-gray-50 transition-colors duration-150"
                            >
                              <td class="px-3 py-2 whitespace-nowrap text-left">
                                <%= if Map.get(ujian, :tarikh_permohonan) do %>
                                  <div class="flex items-center gap-1.5">
                                    <.icon name="hero-calendar-days" class="w-3.5 h-3.5 text-gray-400" />
                                    <span class="text-xs text-gray-700">{Calendar.strftime(ujian.tarikh_permohonan, "%d/%m/%Y")}</span>
                                  </div>
                                <% else %>
                                  <span class="text-xs text-gray-400">—</span>
                                <% end %>
                              </td>
                              <td class="px-3 py-2 whitespace-nowrap text-left">
                                <%= if Map.get(ujian, :tarikh_kelulusan) do %>
                                  <div class="flex items-center gap-1.5">
                                    <.icon name="hero-calendar-days" class="w-3.5 h-3.5 text-gray-400" />
                                    <span class="text-xs text-gray-700">{Calendar.strftime(ujian.tarikh_kelulusan, "%d/%m/%Y")}</span>
                                  </div>
                                <% else %>
                                  <span class="text-xs text-gray-400">—</span>
                                <% end %>
                              </td>
                              <td class="px-3 py-2 text-left">
                                <%= if upload = Map.get(ujian, :upload_file) do %>
                                  <a
                                    href={"/uploads/#{upload}"}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-xs text-blue-600 hover:text-blue-800 underline"
                                  >
                                    {kes_display_filename(upload)}
                                  </a>
                                <% else %>
                                  <span class="text-xs text-gray-400">—</span>
                                <% end %>
                              </td>
                              <td class="px-3 py-2 whitespace-nowrap text-left">
                                <% status_kel = Map.get(ujian, :status_kelulusan) || "—" %>
                                <span class={[
                                  "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border",
                                  case status_kel do
                                    "Lulus" -> "bg-green-100 text-green-800 border-green-200"
                                    "Diluluskan" -> "bg-green-100 text-green-800 border-green-200"
                                    "Gagal" -> "bg-red-100 text-red-800 border-red-200"
                                    "Ditolak" -> "bg-red-100 text-red-800 border-red-200"
                                    "Menunggu" -> "bg-gray-100 text-gray-800 border-gray-200"
                                    _ -> "bg-gray-100 text-gray-800 border-gray-200"
                                  end
                                ]}>
                                  <.icon name={case status_kel do "Lulus" -> "hero-check-circle"; "Diluluskan" -> "hero-check-circle"; "Gagal" -> "hero-x-circle"; "Ditolak" -> "hero-x-circle"; "Menunggu" -> "hero-clock"; _ -> "hero-information-circle" end} class="w-3 h-3 mr-1" />
                                  {status_kel}
                                </span>
                              </td>
                              <td class="px-3 py-2 whitespace-nowrap text-left">
                                <div class="flex items-center gap-1.5">
                                  <%= if is_integer(ujian.id) do %>
                                    <button
                                      type="button"
                                      phx-click="kes_open_edit_modal"
                                      phx-value-ujian_id={ujian.id}
                                      class="p-1.5 text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-md transition-colors duration-200"
                                      title="Edit"
                                    >
                                      <.icon name="hero-pencil" class="w-4 h-4" />
                                    </button>
                                  <% end %>
                                </div>
                              </td>
                            </tr>
                          </tbody>
                        </table>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% @current_tab == "Penempatan" -> %>
              <div class="space-y-6">
                <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                  <div>
                    <h2 class="text-xl font-semibold text-gray-900">Senarai Penempatan</h2>
                    <p class="text-sm text-gray-500 mt-0.5">
                      Pantau status penempatan mengikut versi dan persekitaran.
                    </p>
                  </div>
                  <button
                    type="button"
                    phx-click="open_penempatan_create_modal"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow-md hover:shadow-lg transition-all duration-200 font-medium text-sm"
                  >
                    <.icon name="hero-plus-circle" class="w-5 h-5" />
                    <span>Penempatan Baharu</span>
                  </button>
                </div>

                <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-200">
                  <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-800">
                    <h3 class="text-lg font-semibold text-white">Senarai Penempatan</h3>
                    <p class="text-sm text-blue-100">
                      Pantau status penempatan mengikut versi dan persekitaran.
                    </p>
                  </div>

                  <%= if length(@penempatan) == 0 do %>
                    <div class="px-6 py-12 text-center">
                      <div class="flex flex-col items-center justify-center text-gray-400">
                        <.icon name="hero-inbox" class="w-12 h-12 mb-3" />
                        <p class="text-sm font-medium">Tiada penempatan</p>

                      <p class="text-xs mt-1">
                        Sila daftar penempatan baharu di modul Penempatan.
                      </p>
                      </div>
                    </div>
                  <% else %>
                    <div class="overflow-x-auto">
                      <table class="w-full text-sm">
                        <thead class="bg-gray-50 border-b border-gray-200">
                          <tr>
                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-12">
                              Bil
                            </th>

                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider min-w-[180px]">
                              Nama Sistem
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Versi
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Jenis
                            </th>

                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Lokasi
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Tarikh Penempatan
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Tarikh Permohonan
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Spesifikasi
                            </th>

                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Pemilik Sistem
                            </th>

                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider min-w-[200px]">
                              URL
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-28">
                              Tindakan
                            </th>
                          </tr>
                        </thead>

                        <tbody class="bg-white divide-y divide-gray-200">
                          <tr
                            :for={{penempatan, index} <- Enum.with_index(@penempatan, 1)}
                            class="hover:bg-gray-50 transition-colors duration-150"
                          >
                            <td class="px-3 py-2 text-center">
                              <span class="text-xs text-gray-600 font-medium">{index}</span>
                            </td>

                            <td class="px-3 py-2 text-left">
                              <div class="text-xs text-gray-900 font-semibold line-clamp-1">
                                {penempatan.nama_sistem}
                              </div>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <span class="text-xs text-gray-700">
                                {penempatan.versi || "-"}
                              </span>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <span class="text-xs text-gray-700">
                                {penempatan.jenis || "-"}
                              </span>
                            </td>

                            <td class="px-3 py-2 text-left">
                              <span class="text-xs text-gray-700">
                                {penempatan.lokasi || "-"}
                              </span>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <div class="flex items-center justify-center gap-1.5">
                                <.icon name="hero-calendar-days" class="w-3.5 h-3.5 text-gray-400" />
                                <span class="text-xs text-gray-700">
                                  {Calendar.strftime(penempatan.tarikh_penempatan, "%d/%m/%Y")}
                                </span>
                              </div>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <span class="text-xs text-gray-700">
                                <%= if penempatan.tarikh_dijangka do %>
                                  {Calendar.strftime(penempatan.tarikh_dijangka, "%d/%m/%Y")}
                                <% else %>
                                  -
                                <% end %>
                              </span>
                            </td>

                            <td class="px-3 py-2 text-left">
                              <span class="text-xs text-gray-900">
                                <%= if penempatan.status && penempatan.status != "" do %>
                                  {penempatan.status}
                                <% else %>
                                  -
                                <% end %>
                              </span>
                            </td>

                            <td class="px-3 py-2 text-left">
                              <span class="text-xs text-gray-900">
                                <%= if penempatan.dibina_oleh && penempatan.dibina_oleh != "" do %>
                                  {penempatan.dibina_oleh}
                                <% else %>
                                  -
                                <% end %>
                              </span>
                            </td>

                            <td class="px-3 py-2 text-left min-w-[200px] max-w-[260px]">
                              <%= if penempatan.url && penempatan.url != "" do %>
                                <a
                                  href={penempatan.url}
                                  target="_blank"
                                  class="text-xs text-blue-600 hover:text-blue-800 underline"
                                >
                                  {penempatan.url}
                                </a>
                              <% else %>
                                <span class="text-xs text-gray-400">-</span>
                              <% end %>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <div class="flex items-center justify-center gap-1.5">
                                <button
                                  type="button"
                                  phx-click="open_penempatan_edit_modal"
                                  phx-value-id={penempatan.id}
                                  class="p-1.5 text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-md transition-colors duration-200"
                                  title="Edit"
                                >
                                  <.icon name="hero-pencil" class="w-4 h-4" />
                                </button>
                                <button
                                  type="button"
                                  phx-click="delete_penempatan"
                                  phx-value-id={penempatan.id}
                                  data-confirm="Anda pasti ingin memadam penempatan ini?"
                                  class="p-1.5 text-red-600 hover:text-red-800 hover:bg-red-50 rounded-md transition-colors duration-200"
                                  title="Padam"
                                >
                                  <.icon name="hero-trash" class="w-4 h-4" />
                                </button>
                              </div>
                            </td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  <% end %>
                </div>

                <%!-- Modal: Penempatan Baharu / Kemaskini Penempatan --%>
                <%= if @penempatan_show_create_modal do %>
                  <div class="fixed inset-0 z-50 overflow-y-auto" role="dialog" aria-modal="true">
                    <div
                      class="fixed inset-0 bg-black/60 transition-opacity z-40"
                      aria-hidden="true"
                      phx-click="close_penempatan_create_modal"
                    >
                    </div>
                    <div class="flex min-h-full items-center justify-center p-4 relative z-50 pointer-events-none">
                      <div class="relative w-full max-w-2xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all pointer-events-auto">
                        <div class="border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-5">
                          <div class="flex items-center justify-between">
                            <div>
                              <h2 class="text-xl font-bold text-white">
                                <%= if @penempatan_mode == "edit" do %>
                                  Kemaskini Penempatan
                                <% else %>
                                  Daftar Penempatan Baharu
                                <% end %>
                              </h2>
                              <p class="mt-1 text-sm text-blue-100">
                                Isi maklumat penempatan sistem
                              </p>
                            </div>
                            <button
                              type="button"
                              phx-click="close_penempatan_create_modal"
                              class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50"
                              aria-label="Tutup"
                            >
                              <.icon name="hero-x-mark" class="h-6 w-6" />
                            </button>
                          </div>
                        </div>
                        <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6">
                          <.form
                            for={@penempatan_form}
                            phx-change="validate_penempatan"
                            phx-submit={if(@penempatan_mode == "edit",
                              do: "update_penempatan",
                              else: "create_penempatan"
                            )}
                            id="create-penempatan-form"
                            class="space-y-4"
                          >
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                              <div class="md:col-span-2">
                                <.input
                                  field={@penempatan_form[:nama_sistem]}
                                  type="text"
                                  label="Nama Sistem"
                                  required
                                  placeholder="Nama sistem"
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>
                              <div>
                                <.input
                                  field={@penempatan_form[:versi]}
                                  type="text"
                                  label="Versi"
                                  required
                                  placeholder="Contoh: 1.0.0"
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>
                              <div>
                                <.input
                                  field={@penempatan_form[:lokasi]}
                                  type="text"
                                  label="Lokasi"
                                  required
                                  placeholder="Lokasi penempatan"
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>
                              <div>
                                <label class="block text-sm font-medium text-gray-800 mb-1.5">Jenis</label>
                                <select
                                  name="penempatan[jenis]"
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                >
                                  <option value="Produksi" selected={@penempatan_form[:jenis].value == "Produksi"}>Produksi</option>
                                  <option value="Staging" selected={@penempatan_form[:jenis].value == "Staging"}>Staging</option>
                                  <option value="Development" selected={@penempatan_form[:jenis].value == "Development"}>Development</option>
                                </select>
                              </div>
                              <div>
                                <.input
                                  field={@penempatan_form[:status]}
                                  type="text"
                                  label="Spesifikasi"
                                  placeholder="Contoh: Bahasa, Pangkalan data, Sistem pengendalian"
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>
                              <div>
                                <.input
                                  field={@penempatan_form[:tarikh_penempatan]}
                                  type="date"
                                  label="Tarikh Penempatan"
                                  required
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>
                              <div>
                                <.input
                                  field={@penempatan_form[:tarikh_dijangka]}
                                  type="date"
                                  label="Tarikh Permohonan"
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>
                              <div class="md:col-span-2">
                                <.input
                                  field={@penempatan_form[:url]}
                                  type="text"
                                  label="URL"
                                  placeholder="https://..."
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>
                              <div class="md:col-span-2">
                                <.input
                                  field={@penempatan_form[:dibina_oleh]}
                                  type="text"
                                  label="Pemilik Sistem (Dibina Oleh)"
                                  placeholder="Nama pemilik"
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                                />
                              </div>
                              <div class="md:col-span-2">
                                <.input
                                  field={@penempatan_form[:catatan]}
                                  type="textarea"
                                  label="Catatan"
                                  rows={3}
                                  placeholder="Catatan penempatan..."
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none"
                                />
                              </div>
                            </div>
                          </.form>
                        </div>
                        <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex justify-end gap-3">
                          <button
                            type="button"
                            phx-click="close_penempatan_create_modal"
                            class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium"
                          >
                            Batal
                          </button>
                          <button
                            type="submit"
                            form="create-penempatan-form"
                            class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200 font-medium"
                          >
                            <%= if @penempatan_mode == "edit" do %>
                              Kemaskini Penempatan
                            <% else %>
                              Daftar Penempatan
                            <% end %>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% @current_tab == "Penyerahan" -> %>
              <div class="space-y-6">
                <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                  <div>
                    <h2 class="text-2xl font-bold text-gray-900">Penyerahan</h2>

                    <p class="text-gray-600">
                      Urus dan pantau penyerahan sistem kepada jabatan.
                    </p>
                  </div>

                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:ml-auto">
                    <button
                      type="button"
                      phx-click="penyerahan_open_create_modal"
                      class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 shadow-md hover:shadow-lg transition-all duration-200 font-medium text-sm"
                    >
                      <.icon name="hero-plus-circle" class="w-5 h-5" />
                      <span>Daftar Penyerahan Baharu</span>
                    </button>
                  </div>
                </div>

                <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-200">
                  <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-800">
                    <h3 class="text-lg font-semibold text-white">Senarai Penyerahan</h3>

                    <p class="text-sm text-blue-100">
                      Pantau status penyerahan mengikut versi dan penerima.
                    </p>
                  </div>

                  <%= if length(@penyerahan) == 0 do %>
                    <div class="px-6 py-12 text-center">
                      <div class="flex flex-col items-center justify-center text-gray-400">
                        <.icon name="hero-inbox" class="w-12 h-12 mb-3" />
                        <p class="text-sm font-medium">Tiada penyerahan</p>

                        <p class="text-xs mt-1">
                          Tiada rekod penyerahan pada masa ini.
                        </p>
                      </div>
                    </div>
                  <% else %>
                    <div class="overflow-x-auto">
                      <table class="w-full text-sm">
                        <thead class="bg-gray-50 border-b border-gray-200">
                          <tr>
                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider w-12">
                              Bil.
                            </th>

                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Nama Sistem
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Versi
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Penerima
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Pembangun/Team
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Pengurus Projek
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Status
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Manual Pengguna
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Surat Akuan
                            </th>

                            <th class="px-3 py-2 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Catatan
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Tarikh Penyerahan
                            </th>

                            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">
                              Tindakan
                            </th>
                          </tr>
                        </thead>

                        <tbody class="bg-white divide-y divide-gray-200">
                          <tr
                            :for={{penyerahan, idx} <- Enum.with_index(@penyerahan, 1)}
                            class="hover:bg-gray-50 transition-colors duration-150"
                          >
                            <td class="px-3 py-2 text-center">
                              <span class="text-xs text-gray-600 font-medium">{idx}</span>
                            </td>

                            <td class="px-3 py-2 text-left">
                              <span class="text-xs text-gray-900 font-semibold">
                                {penyerahan.nama_sistem}
                              </span>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <span class="text-xs text-gray-700">{penyerahan.versi}</span>
                            </td>

                            <td class="px-3 py-2 text-left">
                              <span class="text-xs text-gray-700">{penyerahan.penerima}</span>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <span class="text-xs text-gray-700">
                                <%= if penyerahan.pembangun_team do %>
                                  {penyerahan.pembangun_team}
                                <% else %>
                                  <span class="text-gray-400">-</span>
                                <% end %>
                              </span>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <span class="text-xs text-gray-700">
                                <%= if penyerahan.pengurus_projek do %>
                                  {penyerahan.pengurus_projek}
                                <% else %>
                                  <span class="text-gray-400">-</span>
                                <% end %>
                              </span>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <span class={[
                                "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border",
                                case penyerahan.status do
                                  "Menunggu" ->
                                    "bg-gray-100 text-gray-800 border-gray-200"

                                  "Dalam Proses" ->
                                    "bg-yellow-100 text-yellow-800 border-yellow-200"

                                  "Selesai" ->
                                    "bg-green-100 text-green-800 border-green-200"

                                  "Dibatalkan" ->
                                    "bg-red-100 text-red-800 border-red-200"

                                  _ ->
                                    "bg-gray-100 text-gray-800 border-gray-200"
                                end
                              ]}>
                                <.icon
                                  name={
                                    case penyerahan.status do
                                      "Menunggu" -> "hero-clock"
                                      "Dalam Proses" -> "hero-arrow-path"
                                      "Selesai" -> "hero-check-circle"
                                      "Dibatalkan" -> "hero-x-circle"
                                      _ -> "hero-information-circle"
                                    end
                                  }
                                  class="w-3 h-3 mr-1"
                                /> {penyerahan.status}
                              </span>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <%= if penyerahan.manual_pengguna_bahagian_a do %>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                                  <.icon name="hero-document-check" class="w-3 h-3 mr-1" />
                                  <span>Ada</span>
                                </span>
                              <% else %>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200">
                                  <.icon name="hero-minus-circle" class="w-3 h-3 mr-1" />
                                  <span>Belum Ada</span>
                                </span>
                              <% end %>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <%= if penyerahan.surat_akuan_penerimaan do %>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                                  <.icon name="hero-document-check" class="w-3 h-3 mr-1" />
                                  <span>Ada</span>
                                </span>
                              <% else %>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200">
                                  <.icon name="hero-minus-circle" class="w-3 h-3 mr-1" />
                                  <span>Belum Ada</span>
                                </span>
                              <% end %>
                            </td>

                            <td class="px-3 py-2 text-left">
                              <%= if penyerahan.catatan do %>
                                <% is_expanded =
                                  MapSet.member?(
                                    @penyerahan_expanded_catatan || MapSet.new(),
                                    penyerahan.id
                                  ) %>
                                <% catatan_length = String.length(penyerahan.catatan) %>
                                <% should_truncate = catatan_length > 50 %>
                                <div class="text-xs text-gray-700">
                                  <%= if should_truncate do %>
                                    <div>
                                      <span class={if is_expanded, do: "", else: "line-clamp-2"}>
                                        {penyerahan.catatan}
                                      </span>
                                      <button
                                        type="button"
                                        phx-click="penyerahan_toggle_catatan"
                                        phx-value-penyerahan_id={penyerahan.id}
                                        class="ml-1 text-blue-600 hover:text-blue-800 font-medium transition-colors duration-200"
                                      >
                                        <%= if is_expanded do %>
                                          <span>Lihat kurang</span>
                                        <% else %>
                                          <span>Lihat lebih</span>
                                        <% end %>
                                      </button>
                                    </div>
                                  <% else %>
                                    <span>{penyerahan.catatan}</span>
                                  <% end %>
                                </div>
                              <% else %>
                                <span class="text-xs text-gray-400">-</span>
                              <% end %>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <div class="flex items-center justify-center gap-1.5">
                                <.icon
                                  name="hero-calendar-days"
                                  class="w-3.5 h-3.5 text-gray-400"
                                />
                                <span class="text-xs text-gray-700">
                                  <%= if penyerahan.tarikh_penyerahan do %>
                                    {Calendar.strftime(penyerahan.tarikh_penyerahan, "%d/%m/%Y")}
                                  <% else %>
                                    <span class="text-gray-400">-</span>
                                  <% end %>
                                </span>
                              </div>
                            </td>

                            <td class="px-3 py-2 text-center">
                              <div class="flex items-center justify-center gap-1.5">
                                <button
                                  type="button"
                                  phx-click="penyerahan_open_edit_modal"
                                  phx-value-penyerahan_id={penyerahan.id}
                                  class="p-1.5 text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-md transition-colors duration-200"
                                  title="Edit"
                                >
                                  <.icon name="hero-pencil" class="w-4 h-4" />
                                </button>
                                <button
                                  type="button"
                                  phx-click="penyerahan_open_upload_modal"
                                  phx-value-penyerahan_id={penyerahan.id}
                                  class="p-1.5 text-green-600 hover:text-green-800 hover:bg-green-50 rounded-md transition-colors duration-200"
                                  title="Muat Naik Dokumen"
                                >
                                  <.icon name="hero-arrow-up-tray" class="w-4 h-4" />
                                </button>
                              </div>
                            </td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  <% end %>
                </div>
              </div>
            <% @current_tab == "Maklumbalas Pelanggan" -> %>
              <div class="space-y-6">
                <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                  <div>
                    <h2 class="text-2xl font-bold text-gray-900">Maklumbalas Pelanggan</h2>

                    <p class="text-gray-600">
                      Urus dan pantau maklumbalas daripada pelanggan selepas penyerahan
                    </p>
                  </div>
                </div>

                <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-gray-200">
                  <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 border-b border-blue-800">
                    <h3 class="text-lg font-semibold text-white">Maklumbalas Pelanggan</h3>

                    <p class="text-sm text-blue-100">
                      Pantau maklumbalas, aduan dan cadangan penambahbaikan daripada pelanggan.
                    </p>
                  </div>

                  <div class="px-6 py-12 text-center">
                    <div class="flex flex-col items-center justify-center text-gray-400">
                      <.icon name="hero-chat-bubble-left-right" class="w-12 h-12 mb-3" />
                      <p class="text-sm font-medium">Tiada maklumbalas</p>

                      <p class="text-xs mt-1">
                        Kandungan maklumbalas pelanggan akan dipaparkan di sini
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            <% true -> %>
              <div class="py-12 text-center text-gray-500">
                <p class="text-sm font-medium">Kandungan untuk tab ini akan datang.</p>
              </div>
          <% end %>
        </div>
      </main>
    </div>
  </div>

  <%!-- Penyerahan: Create Modal --%>
  <%= if @penyerahan_show_create_modal do %>
    <div
      class="fixed inset-0 z-50 overflow-y-auto"
      phx-click="penyerahan_close_create_modal"
      phx-click-away="penyerahan_close_create_modal"
      role="dialog"
      aria-modal="true"
    >
      <div class="fixed inset-0 bg-black/60 transition-opacity" aria-hidden="true"></div>

      <div class="flex min-h-full items-center justify-center p-4">
        <div
          class="relative w-full max-w-4xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all"
          phx-click-away="penyerahan_close_create_modal"
        >
          <div class="border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-5">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-2xl font-bold text-white">Penyerahan Baharu</h2>
                <p class="mt-1 text-sm text-blue-100">Isi maklumat penyerahan baharu</p>
              </div>

              <button
                type="button"
                phx-click="penyerahan_close_create_modal"
                class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50"
                aria-label="Tutup"
              >
                <.icon name="hero-x-mark" class="h-6 w-6" />
              </button>
            </div>
          </div>

          <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6">
            <.form
              for={@penyerahan_form}
              phx-change="penyerahan_validate"
              phx-submit="penyerahan_create"
              id="projek-tab-penyerahan-create-form"
              class="space-y-6"
            >
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <.input
                    field={@penyerahan_form[:nama_sistem]}
                    type="text"
                    label="Nama Sistem"
                    required
                    placeholder="Masukkan nama sistem"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:versi]}
                    type="text"
                    label="Versi"
                    placeholder="Contoh: 1.0.0"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:penerima]}
                    type="text"
                    label="Jabatan"
                    required
                    placeholder="Masukkan nama jabatan"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:pembangun_team]}
                    type="text"
                    label="Pembangun"
                    placeholder="Masukkan nama pembangun"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:pengurus_projek]}
                    type="text"
                    label="Pengurus"
                    placeholder="Masukkan nama pengurus"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:lokasi]}
                    type="text"
                    label="Lokasi"
                    required
                    placeholder="Masukkan lokasi"
                    class="w-full"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
                  <select
                    name="penyerahan[status]"
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                  >
                    <option
                      value="Menunggu"
                      selected={@penyerahan_form[:status] && @penyerahan_form[:status].value == "Menunggu"}
                    >
                      Menunggu
                    </option>
                    <option
                      value="Dalam Proses"
                      selected={@penyerahan_form[:status] && @penyerahan_form[:status].value == "Dalam Proses"}
                    >
                      Dalam Proses
                    </option>
                    <option
                      value="Selesai"
                      selected={@penyerahan_form[:status] && @penyerahan_form[:status].value == "Selesai"}
                    >
                      Selesai
                    </option>
                    <option
                      value="Dibatalkan"
                      selected={@penyerahan_form[:status] && @penyerahan_form[:status].value == "Dibatalkan"}
                    >
                      Dibatalkan
                    </option>
                  </select>
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:tarikh_dijangka]}
                    type="date"
                    label="Tarikh Dijangka"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:tarikh_penyerahan]}
                    type="date"
                    label="Tarikh Penyerahan"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:diserahkan_oleh]}
                    type="text"
                    label="Diserahkan Oleh"
                    placeholder="Masukkan nama"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:diterima_oleh]}
                    type="text"
                    label="Diterima Oleh"
                    placeholder="Masukkan nama"
                    class="w-full"
                  />
                </div>

                <div class="md:col-span-2">
                  <label class="block text-sm font-medium text-gray-700 mb-2">Catatan</label>
                  <textarea
                    name="penyerahan[catatan]"
                    rows="4"
                    placeholder="Masukkan catatan..."
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none"
                  ><%= if @penyerahan_form[:catatan] && @penyerahan_form[:catatan].value, do: @penyerahan_form[:catatan].value, else: "" %></textarea>
                </div>
              </div>

              <div class="flex items-center justify-end gap-3 border-t border-gray-200 pt-6">
                <button
                  type="button"
                  phx-click="penyerahan_close_create_modal"
                  class="px-6 py-2.5 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-all duration-200 font-medium"
                >
                  Batal
                </button>
                <button
                  type="submit"
                  class="px-6 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 shadow-md hover:shadow-lg transition-all duration-200 font-medium"
                >
                  Daftar Penyerahan
                </button>
              </div>
            </.form>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%!-- Penyerahan: Edit Modal --%>
  <%= if @penyerahan_show_edit_modal do %>
    <div
      class="fixed inset-0 z-50 overflow-y-auto"
      phx-click="penyerahan_close_edit_modal"
      phx-click-away="penyerahan_close_edit_modal"
      role="dialog"
      aria-modal="true"
    >
      <div class="fixed inset-0 bg-black/60 transition-opacity" aria-hidden="true"></div>

      <div class="flex min-h-full items-center justify-center p-4">
        <div
          class="relative w-full max-w-4xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all"
          phx-click-away="penyerahan_close_edit_modal"
        >
          <div class="border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-5">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-2xl font-bold text-white">Kemaskini Penyerahan</h2>
                <p class="mt-1 text-sm text-blue-100">Kemaskini maklumat penyerahan</p>
              </div>

              <button
                type="button"
                phx-click="penyerahan_close_edit_modal"
                class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50"
                aria-label="Tutup"
              >
                <.icon name="hero-x-mark" class="h-6 w-6" />
              </button>
            </div>
          </div>

          <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6">
            <.form
              for={@penyerahan_form}
              phx-change="penyerahan_validate"
              phx-submit="penyerahan_update"
              id="projek-tab-penyerahan-edit-form"
              class="space-y-6"
            >
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <.input
                    field={@penyerahan_form[:nama_sistem]}
                    type="text"
                    label="Nama Sistem"
                    required
                    placeholder="Masukkan nama sistem"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:versi]}
                    type="text"
                    label="Versi"
                    placeholder="Contoh: 1.0.0"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:penerima]}
                    type="text"
                    label="Jabatan"
                    required
                    placeholder="Masukkan nama jabatan"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:pembangun_team]}
                    type="text"
                    label="Pembangun"
                    placeholder="Masukkan nama pembangun"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:pengurus_projek]}
                    type="text"
                    label="Pengurus"
                    placeholder="Masukkan nama pengurus"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:lokasi]}
                    type="text"
                    label="Lokasi"
                    required
                    placeholder="Masukkan lokasi"
                    class="w-full"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
                  <select
                    name="penyerahan[status]"
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200"
                  >
                    <option
                      value="Menunggu"
                      selected={@penyerahan_form[:status] && @penyerahan_form[:status].value == "Menunggu"}
                    >
                      Menunggu
                    </option>
                    <option
                      value="Dalam Proses"
                      selected={@penyerahan_form[:status] && @penyerahan_form[:status].value == "Dalam Proses"}
                    >
                      Dalam Proses
                    </option>
                    <option
                      value="Selesai"
                      selected={@penyerahan_form[:status] && @penyerahan_form[:status].value == "Selesai"}
                    >
                      Selesai
                    </option>
                    <option
                      value="Dibatalkan"
                      selected={@penyerahan_form[:status] && @penyerahan_form[:status].value == "Dibatalkan"}
                    >
                      Dibatalkan
                    </option>
                  </select>
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:tarikh_dijangka]}
                    type="date"
                    label="Tarikh Dijangka"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:tarikh_penyerahan]}
                    type="date"
                    label="Tarikh Penyerahan"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:diserahkan_oleh]}
                    type="text"
                    label="Diserahkan Oleh"
                    placeholder="Masukkan nama"
                    class="w-full"
                  />
                </div>

                <div>
                  <.input
                    field={@penyerahan_form[:diterima_oleh]}
                    type="text"
                    label="Diterima Oleh"
                    placeholder="Masukkan nama"
                    class="w-full"
                  />
                </div>

                <div class="md:col-span-2">
                  <label class="block text-sm font-medium text-gray-700 mb-2">Catatan</label>
                  <textarea
                    name="penyerahan[catatan]"
                    rows="4"
                    placeholder="Masukkan catatan..."
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none"
                  ><%= if @penyerahan_form[:catatan] && @penyerahan_form[:catatan].value, do: @penyerahan_form[:catatan].value, else: "" %></textarea>
                </div>
              </div>

              <div class="flex items-center justify-end gap-3 border-t border-gray-200 pt-6">
                <button
                  type="button"
                  phx-click="penyerahan_close_edit_modal"
                  class="px-6 py-2.5 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-all duration-200 font-medium"
                >
                  Batal
                </button>
                <button
                  type="submit"
                  class="px-6 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 shadow-md hover:shadow-lg transition-all duration-200 font-medium"
                >
                  Simpan
                </button>
              </div>
            </.form>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%!-- Penyerahan: Upload Modal --%>
  <%= if @penyerahan_show_upload_modal do %>
    <div
      class="fixed inset-0 z-50 overflow-y-auto"
      phx-click="penyerahan_close_upload_modal"
      phx-click-away="penyerahan_close_upload_modal"
      role="dialog"
      aria-modal="true"
    >
      <div class="fixed inset-0 bg-black/60 transition-opacity" aria-hidden="true"></div>

      <div class="flex min-h-full items-center justify-center p-4">
        <div
          class="relative w-full max-w-3xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all"
          phx-click-away="penyerahan_close_upload_modal"
        >
          <div class="border-b border-gray-200 bg-gradient-to-r from-green-600 to-green-700 px-6 py-5">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-2xl font-bold text-white">Muat Naik Dokumen</h2>
                <p class="mt-1 text-sm text-green-100">
                  Muat naik Manual Pengguna Bahagian A dan Surat Akuan Penerimaan Aplikasi
                </p>
              </div>

              <button
                type="button"
                phx-click="penyerahan_close_upload_modal"
                class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50"
                aria-label="Tutup"
              >
                <.icon name="hero-x-mark" class="h-6 w-6" />
              </button>
            </div>
          </div>

          <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">
                  Manual Pengguna Bahagian A
                </h3>

                <%= if @penyerahan_uploading_penyerahan &&
                      @penyerahan_uploading_penyerahan.manual_pengguna_bahagian_a do %>
                  <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg">
                    <div class="flex items-center gap-2">
                      <.icon name="hero-document-check" class="w-5 h-5 text-green-600" />
                      <div class="flex-1">
                        <p class="text-sm font-medium text-green-900">Dokumen sedia ada</p>
                        <p class="text-xs text-green-700 mt-1">
                          {@penyerahan_uploading_penyerahan.manual_pengguna_bahagian_a}
                        </p>
                        <p class="text-xs text-green-600 mt-1 italic">
                          Muat naik dokumen baharu akan menggantikan dokumen sedia ada
                        </p>
                      </div>
                    </div>
                  </div>
                <% end %>

                <.form
                  for={@penyerahan_upload_manual_form}
                  phx-change="penyerahan_validate_upload_manual"
                  phx-submit="penyerahan_upload_manual"
                  id="projek-tab-penyerahan-upload-manual-form"
                  multipart={true}
                  class="space-y-4"
                >
                  <input
                    type="hidden"
                    name="upload_manual[penyerahan_id]"
                    value={@penyerahan_uploading_penyerahan_id}
                  />
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Pilih Fail</label>
                    <div class="mt-1 flex justify-center rounded-lg border-2 border-dashed border-gray-300 px-6 py-4 transition hover:border-green-600 hover:bg-gray-50">
                      <div class="text-center">
                        <.icon name="hero-document-arrow-up" class="mx-auto h-10 w-10 text-gray-400" />
                        <div class="mt-3 flex text-sm leading-6 text-gray-600">
                          <label
                            for="projek-tab-manual-upload"
                            class="relative cursor-pointer rounded-md bg-white font-semibold text-green-600 focus-within:outline-none focus-within:ring-2 focus-within:ring-green-600 focus-within:ring-offset-2"
                          >
                            <span>Pilih fail</span>
                            <input
                              id="projek-tab-manual-upload"
                              name="upload_manual[file]"
                              type="file"
                              accept=".pdf,.doc,.docx"
                              class="sr-only"
                            />
                          </label>
                          <p class="pl-1">atau seret dan lepaskan</p>
                        </div>
                        <p class="mt-2 text-xs leading-5 text-gray-600">
                          PDF, DOC, DOCX sehingga 10MB
                        </p>
                      </div>
                    </div>
                  </div>
                </.form>
              </div>

              <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">
                  Surat Akuan Penerimaan Aplikasi
                </h3>

                <%= if @penyerahan_uploading_penyerahan &&
                      @penyerahan_uploading_penyerahan.surat_akuan_penerimaan do %>
                  <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg">
                    <div class="flex items-center gap-2">
                      <.icon name="hero-document-check" class="w-5 h-5 text-green-600" />
                      <div class="flex-1">
                        <p class="text-sm font-medium text-green-900">Dokumen sedia ada</p>
                        <p class="text-xs text-green-700 mt-1">
                          {@penyerahan_uploading_penyerahan.surat_akuan_penerimaan}
                        </p>
                        <p class="text-xs text-green-600 mt-1 italic">
                          Muat naik dokumen baharu akan menggantikan dokumen sedia ada
                        </p>
                      </div>
                    </div>
                  </div>
                <% end %>

                <.form
                  for={@penyerahan_upload_surat_form}
                  phx-change="penyerahan_validate_upload_surat"
                  phx-submit="penyerahan_upload_surat"
                  id="projek-tab-penyerahan-upload-surat-form"
                  multipart={true}
                  class="space-y-4"
                >
                  <input
                    type="hidden"
                    name="upload_surat[penyerahan_id]"
                    value={@penyerahan_uploading_penyerahan_id}
                  />
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Pilih Fail</label>
                    <div class="mt-1 flex justify-center rounded-lg border-2 border-dashed border-gray-300 px-6 py-4 transition hover:border-green-600 hover:bg-gray-50">
                      <div class="text-center">
                        <.icon name="hero-document-arrow-up" class="mx-auto h-10 w-10 text-gray-400" />
                        <div class="mt-3 flex text-sm leading-6 text-gray-600">
                          <label
                            for="projek-tab-surat-upload"
                            class="relative cursor-pointer rounded-md bg-white font-semibold text-green-600 focus-within:outline-none focus-within:ring-2 focus-within:ring-green-600 focus-within:ring-offset-2"
                          >
                            <span>Pilih fail</span>
                            <input
                              id="projek-tab-surat-upload"
                              name="upload_surat[file]"
                              type="file"
                              accept=".pdf,.doc,.docx"
                              class="sr-only"
                            />
                          </label>
                          <p class="pl-1">atau seret dan lepaskan</p>
                        </div>
                        <p class="mt-2 text-xs leading-5 text-gray-600">
                          PDF, DOC, DOCX sehingga 10MB
                        </p>
                      </div>
                    </div>
                  </div>
                </.form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%!-- Ujian Keselamatan: Daftar Ujian Baharu Modal --%>
  <%= if assigns[:kes_show_create_modal] do %>
    <div class="fixed inset-0 z-[60] flex items-center justify-center bg-gray-900/60 backdrop-blur-sm">
      <div class="bg-white rounded-2xl shadow-2xl max-w-xl w-full mx-4 overflow-hidden border border-gray-200">
        <div class="px-6 py-4 bg-gradient-to-r from-blue-600 to-blue-700 flex items-center justify-between">
          <div>
            <h3 class="text-base font-semibold text-white">Daftar Ujian Keselamatan Baharu</h3>
            <p class="text-[11px] text-blue-100 mt-0.5">
              Lengkapkan maklumat permohonan ujian keselamatan.
            </p>
          </div>
          <button
            type="button"
            phx-click="close_kes_create_modal"
            class="text-blue-100 hover:text-white rounded-full p-1.5 hover:bg-white/10 transition"
          >
            <.icon name="hero-x-mark" class="w-5 h-5" />
          </button>
        </div>
        <div class="px-6 py-5 space-y-4 max-h-[75vh] overflow-y-auto">
          <.form
            for={@kes_form}
            id="kes-create-ujian-form"
            phx-submit="kes_create_ujian"
            phx-change="kes_validate_ujian"
          >
            <div class="grid grid-cols-1 gap-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Tarikh Permohonan</label>
                  <input
                    type="date"
                    name="ujian[tarikh_permohonan]"
                    value={@kes_form[:tarikh_permohonan].value || ""}
                    class="block w-full rounded-md border border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 text-gray-900"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Tarikh Kelulusan</label>
                  <input
                    type="date"
                    name="ujian[tarikh_kelulusan]"
                    value={@kes_form[:tarikh_kelulusan].value || ""}
                    class="block w-full rounded-md border border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 text-gray-900"
                  />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Upload File</label>
                <div class="mt-1 flex items-center gap-3">
                  <.live_file_input upload={@uploads.kes_file} class="hidden" />
                  <button
                    type="button"
                    phx-click={JS.dispatch("click", to: "#" <> to_string(@uploads.kes_file.ref))}
                    class="cursor-pointer inline-flex items-center gap-2 px-4 py-2 border border-gray-300 rounded-lg bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition"
                  >
                    <.icon name="hero-arrow-up-tray" class="w-5 h-5" />
                    <span>Pilih fail</span>
                  </button>
                  <span class="text-sm text-gray-500">
                    <%= if Enum.empty?(@uploads.kes_file.entries) do %>
                      PDF, DOC, XLS, imej (maks 10MB)
                    <% else %>
                      <%= for entry <- @uploads.kes_file.entries do %>
                        {entry.client_name}
                        <%= if entry.progress < 100 do %>
                          <span class="text-blue-600">({entry.progress}%)</span>
                        <% end %>
                      <% end %>
                    <% end %>
                  </span>
                </div>
                <%= for err <- upload_errors(@uploads.kes_file) do %>
                  <p class="mt-1 text-sm text-red-600"><%= kes_upload_error_to_string(err) %></p>
                <% end %>
                <%= for entry <- @uploads.kes_file.entries do %>
                  <%= for err <- upload_errors(@uploads.kes_file, entry) do %>
                    <p class="mt-1 text-sm text-red-600"><%= kes_upload_error_to_string(err) %></p>
                  <% end %>
                <% end %>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Status Kelulusan</label>
                <select
                  name="ujian[status_kelulusan]"
                  class="block w-full rounded-md border border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 text-gray-900"
                  value={@kes_form[:status_kelulusan].value || "Lulus"}
                >
                  <option value="Lulus">Lulus</option>
                  <option value="Gagal">Gagal</option>
                </select>
              </div>
            </div>
            <div class="mt-6 flex items-center justify-between gap-3">
              <button
                type="button"
                phx-click="close_kes_create_modal"
                class="inline-flex items-center justify-center gap-2 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg bg-white hover:bg-gray-50 text-sm font-medium shadow-sm transition"
              >
                <span>Batal</span>
              </button>
              <button
                type="submit"
                class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg hover:from-blue-700 hover:to-blue-800 text-sm font-medium shadow-md hover:shadow-lg transition"
              >
                <span>Simpan</span>
              </button>
            </div>
          </.form>
        </div>
      </div>
    </div>
  <% end %>

  <%!-- Ujian Keselamatan: Edit Ujian Modal --%>
  <%= if assigns[:kes_show_edit_modal] && assigns[:kes_editing_ujian] do %>
    <div class="fixed inset-0 z-50 overflow-y-auto" role="dialog" aria-modal="true">
      <div class="fixed inset-0 bg-black/60 transition-opacity" aria-hidden="true" phx-click="kes_close_edit_modal"></div>
      <div class="flex min-h-full items-center justify-center p-4 pointer-events-none">
        <div class="relative w-full max-w-3xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all pointer-events-auto">
          <div class="border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-5">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-2xl font-bold text-white">Kemaskini Ujian Keselamatan</h2>
                <p class="mt-1 text-sm text-blue-100">Edit maklumat ujian keselamatan</p>
              </div>
              <button type="button" phx-click="kes_close_edit_modal" class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50" aria-label="Tutup">
                <.icon name="hero-x-mark" class="h-6 w-6" />
              </button>
            </div>
          </div>
          <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6 text-gray-900">
            <.form for={@kes_form} phx-change="kes_validate_ujian" phx-submit="kes_update_ujian" id="kes-edit-ujian-form" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="kes-edit-tarikh-permohonan" class="block text-sm font-medium text-gray-700 mb-1">Tarikh Permohonan</label>
                  <input
                    type="date"
                    name="ujian[tarikh_permohonan]"
                    id="kes-edit-tarikh-permohonan"
                    value={@kes_form[:tarikh_permohonan].value || ""}
                    class="block w-full rounded-md border border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 text-gray-900"
                  />
                </div>
                <div>
                  <label for="kes-edit-tarikh-kelulusan" class="block text-sm font-medium text-gray-700 mb-1">Tarikh Kelulusan</label>
                  <input
                    type="date"
                    name="ujian[tarikh_kelulusan]"
                    id="kes-edit-tarikh-kelulusan"
                    value={@kes_form[:tarikh_kelulusan].value || ""}
                    class="block w-full rounded-md border border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 text-gray-900"
                  />
                </div>
                <div class="md:col-span-2">
                  <input type="hidden" name="ujian[upload_file]" value={@kes_form[:upload_file].value || ""} />
                  <label class="block text-sm font-medium text-gray-700 mb-1">Upload File</label>
                  <%= if @kes_form[:upload_file].value && @kes_form[:upload_file].value != "" do %>
                    <p class="text-sm text-gray-600 mb-2">
                      Fail semasa:
                      <a
                        href={"/uploads/#{@kes_form[:upload_file].value}"}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-blue-600 hover:text-blue-800 underline ml-1"
                      >
                        {kes_display_filename(@kes_form[:upload_file].value)}
                      </a>
                    </p>
                  <% end %>
                  <div class="flex items-center gap-3 flex-wrap">
                    <.live_file_input upload={@uploads.kes_edit_file} class="hidden" />
                    <button
                      type="button"
                      phx-click={JS.dispatch("click", to: "#" <> to_string(@uploads.kes_edit_file.ref))}
                      class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 rounded-lg bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition"
                    >
                      <.icon name="hero-arrow-up-tray" class="w-5 h-5" />
                      <span>Muat naik semula</span>
                    </button>
                    <span class="text-sm text-gray-500">
                      <%= if Enum.empty?(@uploads.kes_edit_file.entries) do %>
                        Pilih fail baru untuk gantikan (PDF, DOC, XLS, imej, maks 10MB)
                      <% else %>
                        <%= for entry <- @uploads.kes_edit_file.entries do %>
                          Fail baharu: {entry.client_name}
                          <%= if entry.progress < 100 do %>
                            <span class="text-blue-600">({entry.progress}%)</span>
                          <% end %>
                        <% end %>
                      <% end %>
                    </span>
                  </div>
                  <%= for err <- upload_errors(@uploads.kes_edit_file) do %>
                    <p class="mt-1 text-sm text-red-600"><%= kes_upload_error_to_string(err) %></p>
                  <% end %>
                  <%= for entry <- @uploads.kes_edit_file.entries do %>
                    <%= for err <- upload_errors(@uploads.kes_edit_file, entry) do %>
                      <p class="mt-1 text-sm text-red-600"><%= kes_upload_error_to_string(err) %></p>
                    <% end %>
                  <% end %>
                </div>
                <div>
                  <label for="kes-edit-status-kelulusan" class="block text-sm font-medium text-gray-700 mb-1">Status Kelulusan</label>
                  <select
                    name="ujian[status_kelulusan]"
                    id="kes-edit-status-kelulusan"
                    class="block w-full rounded-md border border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 text-gray-900"
                  >
                    <option value="Lulus" selected={@kes_form[:status_kelulusan].value == "Lulus"}>Lulus</option>
                    <option value="Gagal" selected={@kes_form[:status_kelulusan].value == "Gagal"}>Gagal</option>
                  </select>
                </div>
              </div>
            </.form>
          </div>
          <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex justify-end gap-3">
            <button type="button" phx-click="kes_close_edit_modal" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium">Batal</button>
            <button type="submit" form="kes-edit-ujian-form" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200 font-medium">Simpan Perubahan</button>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%!-- Ujian Keselamatan: Edit Kes Ujian Modal --%>
  <%= if assigns[:kes_show_edit_kes_modal] && assigns[:kes_selected_kes] do %>
    <div class="fixed inset-0 z-50 overflow-y-auto" role="dialog" aria-modal="true">
      <div class="fixed inset-0 bg-black/60 transition-opacity" aria-hidden="true" phx-click="kes_close_edit_kes_modal"></div>
      <div class="flex min-h-full items-center justify-center p-4 pointer-events-none">
        <div class="relative w-full max-w-4xl transform overflow-hidden rounded-2xl bg-white shadow-2xl transition-all pointer-events-auto">
          <div class="border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-5">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-2xl font-bold text-white">Kemaskini Kes Ujian</h2>
                <p class="mt-1 text-sm text-blue-100">Edit maklumat kes ujian: {@kes_selected_kes[:kod] || @kes_selected_kes.id}</p>
              </div>
              <button type="button" phx-click="kes_close_edit_kes_modal" class="rounded-lg p-2 text-white/80 transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50" aria-label="Tutup">
                <.icon name="hero-x-mark" class="h-6 w-6" />
              </button>
            </div>
          </div>
          <div class="max-h-[calc(100vh-200px)] overflow-y-auto px-6 py-6">
            <.form for={@kes_kes_form} phx-change="kes_validate_kes" phx-submit="kes_update_kes" id="kes-edit-kes-form" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="md:col-span-2">
                  <.input field={@kes_kes_form[:senario]} type="text" label="Senario Ujian" required placeholder="Masukkan senario ujian" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200" />
                </div>
                <div class="md:col-span-2">
                  <.input field={@kes_kes_form[:langkah]} type="textarea" label="Langkah Ujian" rows="4" placeholder="Masukkan langkah ujian..." class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none" />
                </div>
                <div class="md:col-span-2">
                  <.input field={@kes_kes_form[:keputusan_dijangka]} type="textarea" label="Keputusan Dijangka" rows="3" placeholder="Masukkan keputusan dijangka..." class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none" />
                </div>
                <div class="md:col-span-2">
                  <.input field={@kes_kes_form[:keputusan_sebenar]} type="textarea" label="Keputusan Sebenar" rows="3" placeholder="Masukkan keputusan sebenar..." class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-600 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 resize-none" />
                </div>
                <div>
                  <.input field={@kes_kes_form[:hasil]} type="select" label="Hasil" prompt="Belum Selesai" options={["Lulus", "Gagal"]} class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200" />
                </div>
                <div>
                  <.input field={@kes_kes_form[:penguji]} type="text" label="Di Uji Oleh" placeholder="Masukkan nama penguji" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200" />
                </div>
                <div>
                  <.input field={@kes_kes_form[:tarikh_ujian]} type="date" id="kes-kes-tarikh-ujian" label="Tarikh Ujian" class="w-full px-4 py-2.5 pr-10 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200" />
                </div>
                <div>
                  <.input field={@kes_kes_form[:disahkan_oleh]} type="text" label="Disahkan Oleh" placeholder="Masukkan nama pegawai yang mengesahkan" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200" />
                </div>
                <div>
                  <.input field={@kes_kes_form[:tarikh_pengesahan]} type="date" id="kes-kes-tarikh-pengesahan" label="Tarikh Pengesahan" class="w-full px-4 py-2.5 pr-10 border border-gray-300 rounded-lg text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200" />
                </div>
              </div>
            </.form>
          </div>
          <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex justify-end gap-3">
            <button type="button" phx-click="kes_close_edit_kes_modal" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors duration-200 font-medium">Batal</button>
            <button type="submit" form="kes-edit-kes-form" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200 font-medium">Simpan</button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</Layouts.app>
